---
import Layout from '../layouts/Layout.astro';
import { companyConfig } from '../data/companyConfig';

// Komponenty
import Wprowadzenie from '../components/narzedzia/Wprowadzenie.astro';
import Kalkulator from '../components/narzedzia/Kalkulator.astro';
import Konwersja from '../components/narzedzia/Konwersja.astro';

// [SEO]: Meta-dane
const pageTitle = "Kalkulator Doboru i Oszczędności Klimatyzacji | AirTUR";
const pageDescription = "Skorzystaj z darmowego narzędzia AirTUR. Oblicz zapotrzebowanie na moc chłodniczą i grzewczą, poznaj potencjalne oszczędności i otrzymaj raport PDF.";

const sectionWrapperClass = "scroll-mt-24";

// [SEO & SENIOR]: Schema WebApplication + PotentialAction
const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Kalkulator Oszczędności i Doboru Klimatyzacji AirTUR",
  "url": "https://airtur.pl/narzedzia",
  "description": pageDescription,
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "All",
  "provider": {
    "@type": "LocalBusiness",
    "name": companyConfig.name,
    "telephone": companyConfig.contact.phoneFull,
    "image": "https://airtur.pl/assets/hero.jpg"
  },
  "potentialAction": {
    "@type": "UseAction",
    "target": "https://airtur.pl/narzedzia"
  }
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <main id="main-content" class="bg-white overflow-x-hidden outline-none">
    
    <section id="wprowadzenie" class={sectionWrapperClass} aria-label="Wprowadzenie do narzędzia">
      <Wprowadzenie />
    </section>

    <section id="kalkulator-interfejs" class="pt-0 pb-0" aria-label="Interfejs kalkulatora doboru mocy">
        <Kalkulator />
    </section>
    
    <section id="konwersja-wrapper" aria-hidden="true" aria-live="polite" class="hidden opacity-0 translate-y-10 transition-all duration-1000 ease-out border-t border-gray-100 -mt-24 relative z-10" aria-label="Formularz wysyłki raportu">
        <Konwersja />
    </section>
    
  </main>
</Layout>

<script>
  /**
   * [ARCHITEKTURA]: Event-Driven Pattern. 
   * Czekamy aż Kalkulator rzuci eventem 'calculator:completed' lub 'calculator:reset'.
   * Zero hard-dependencies (jak DOM MutationObserver).
   */
  document.addEventListener('DOMContentLoaded', () => {
    const konwersjaWrapper = document.getElementById('konwersja-wrapper');
    if (!konwersjaWrapper) return;

    // EVENT: Koniec Kalkulatora (Pokazanie konwersji)
    document.addEventListener('calculator:completed', () => {
        // 1. Zdejmujemy display: none
        konwersjaWrapper.classList.remove('hidden');
        konwersjaWrapper.setAttribute('aria-hidden', 'false');
        
        // 2. Wymuszamy Reflow przeglądarki (żeby CSS Transition zaskoczyło po display:none)
        void konwersjaWrapper.offsetWidth; 

        // 3. Odpalamy animację
        requestAnimationFrame(() => {
            konwersjaWrapper.classList.remove('opacity-0', 'translate-y-10');
        });

        // 4. [ANALYTICS]: Wysyłamy event do GTM / GA4
        if (typeof window !== 'undefined' && window.gtag) {
            window.gtag('event', 'conversion_section_shown', {
                'event_category': 'Calculator',
                'event_label': 'Step 4 Reached'
            });
        }
    });

    // EVENT: Reset Kalkulatora (Ukrycie konwersji)
    document.addEventListener('calculator:reset', () => {
        konwersjaWrapper.classList.add('opacity-0', 'translate-y-10');
        konwersjaWrapper.setAttribute('aria-hidden', 'true');
        
        // Czekamy na koniec animacji (1000ms zadeklarowane w Tailwind) zanim damy display:none
        setTimeout(() => {
            konwersjaWrapper.classList.add('hidden');
        }, 1000);
    });
  });
</script>

<style is:global>
  html { scroll-behavior: smooth; }
  body { -webkit-overflow-scrolling: touch; text-rendering: optimizeLegibility; }
  * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
</style>