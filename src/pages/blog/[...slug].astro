---
export const prerender = true;
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import { BLOG_AUTHORS } from '../../content/config';

/** * [SENIOR NOTE]: Szablon Artykułu v4.4 - Full Feature Parity.
 * Wdrożono system stanów FAQ (data-state) zgodny z Bazą Wiedzy.
 * Naprawiono logikę widoczności przycisku TOC (zakładki).
 */

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings: rawHeadings } = await entry.render();

const headings = rawHeadings.filter(h => !h.text.toLowerCase().includes('faq'));

if (entry.data.faq && entry.data.faq.length > 0) {
  headings.push({
    depth: 2,               
    slug: 'faq-sekcja',
    text: 'FAQ – Pytania i odpowiedzi' 
  });
}

const seoTitle = entry.data.meta?.title || `${entry.data.title} | Ekspertyza AirTUR`;
const seoDescription = entry.data.meta?.description || entry.data.excerpt;
const showTOC = entry.data.showTOC;

const rawAuthorInput = entry.data.author ? entry.data.author.trim() : '';
const authorKey = rawAuthorInput.toLowerCase();
const authorData = BLOG_AUTHORS[authorKey] || BLOG_AUTHORS['default'];
---

<Layout title={seoTitle} description={seoDescription}>
  
  <header class="bg-airtur-dark text-white pt-20 pb-12 md:pt-24 md:pb-16 relative overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-airtur-blue rounded-full blur-[120px] animate-pulse"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="max-w-4xl text-center md:text-left">
          <span class="inline-block bg-airtur-blue text-white text-[10px] font-black px-3 py-1.5 rounded-md uppercase tracking-[0.2em] mb-3 shadow-lg shadow-airtur-blue/20">
            {entry.data.category}
          </span>
          
          <h1 class="text-3xl md:text-5xl lg:text-6xl font-black leading-[1.1] tracking-tight text-balance uppercase">
            {entry.data.title}
          </h1>

          {entry.data.updatedDate && (
            <div class="inline-flex mt-6 px-4 py-2 bg-white/5 border border-white/10 rounded-xl text-airtur-blue text-[10px] font-black uppercase tracking-widest backdrop-blur-sm">
                ✨ Aktualizacja: {entry.data.updatedDate.toLocaleDateString('pl-PL')}
            </div>
          )}
        </div>

        <div class="flex flex-wrap md:flex-col items-center md:items-end justify-center md:justify-start gap-4 md:gap-2 text-[10px] font-black uppercase tracking-widest text-gray-400">
            <span class="flex items-center gap-2 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-airtur-blue"><path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" /></svg>
                {authorData.name}
            </span>
            <span class="hidden md:block opacity-20 text-white">|</span>
            <span class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" /></svg>
                {entry.data.readingTime}
            </span>
        </div>
      </div>
    </div>
  </header>

  <article class="py-8 md:py-16 bg-white relative">
    
    {showTOC && (
      <button 
        id="toc-reopen-btn" 
        class="hidden lg:hidden fixed right-0 top-32 z-40 bg-airtur-dark border border-white/10 text-white pl-5 pr-4 py-3 rounded-l-2xl shadow-2xl hover:text-airtur-blue hover:pl-8 transition-all duration-300 group opacity-0 pointer-events-none items-center gap-3"
      >
          <span class="text-[11px] font-black uppercase tracking-[0.2em] whitespace-nowrap">Spis treści</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
      </button>
    )}

    <div id="main-grid" class={`mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl ${showTOC ? 'grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20' : ''}`}>
      
      {showTOC && (
        <aside id="sidebar-toc" class="w-full lg:col-span-4 order-first lg:order-last mb-8 lg:mb-0">
            <div class="lg:sticky lg:top-24">
                <TableOfContents headings={headings} />
            </div>
        </aside>
      )}

      <div id="content-col" class={`${showTOC ? 'lg:col-span-8' : 'w-full max-w-4xl mx-auto'} transition-all duration-500`}>

        <div class="rounded-[2.5rem] overflow-hidden shadow-2xl mb-12 border border-gray-100 aspect-video bg-gray-50 relative group">
            <img src={entry.data.image} alt={entry.data.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        </div>

        {entry.data.keyTakeaways && (
            <div class="bg-airtur-blue/5 border border-airtur-blue/10 p-8 md:p-10 rounded-[2.5rem] mb-12 relative overflow-hidden">
                <div class="absolute -right-4 -top-4 text-airtur-blue/10">
                    <svg class="w-24 h-24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                </div>
                <h3 class="text-xl font-black text-airtur-dark mb-6 flex items-center gap-3 uppercase tracking-tight">W tym raporcie:</h3>
                <ul class="space-y-4">
                    {entry.data.keyTakeaways.map(p => (
                      <li class="flex items-start gap-4 text-gray-700 text-base md:text-lg font-medium leading-relaxed">
                        <span class="text-airtur-blue shrink-0 mt-1.5"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg></span>
                        <span>{p}</span>
                      </li>
                    ))}
                </ul>
            </div>
        )}

        <div id="inner-content" class="prose-airtur">
            <Content />
        </div>

        {entry.data.faq && entry.data.faq.length > 0 && (
            <div class="mt-20 pt-12 border-t border-gray-100">
                <h3 id="faq-sekcja" class="text-2xl md:text-3xl font-black text-airtur-dark mb-10 scroll-mt-24 uppercase tracking-tight">
                    FAQ – <span class="text-airtur-blue">Techniczne Wyjaśnienie</span>
                </h3>
                <div class="space-y-4">
                    {entry.data.faq.map((item, index) => (
                        <div 
                          id={`faq-${index}`} 
                          class="faq-item border border-gray-100 rounded-[1.5rem] overflow-hidden bg-white transition-all duration-300 hover:border-airtur-blue/20 scroll-mt-24"
                          data-state="closed"
                        >
                            <button class="faq-toggle w-full flex justify-between items-center p-6 text-left focus:outline-none group" aria-expanded="false">
                                <span class="text-base md:text-lg font-black text-airtur-dark group-hover:text-airtur-blue transition-colors pr-6">{item.question}</span>
                                <div class="relative w-5 h-5 flex items-center justify-center text-airtur-blue flex-shrink-0">
                                  <span class="absolute w-full h-0.5 bg-current transform transition-transform duration-300"></span>
                                  <span class="absolute h-full w-0.5 bg-current transform transition-transform duration-300 icon-vertical"></span>
                                </div>
                            </button>
                            <div class="faq-answer overflow-hidden transition-[max-height] duration-500 ease-in-out" style="max-height: 0px;">
                              <div class="p-6 pt-0 text-base text-gray-600 leading-relaxed border-t border-transparent content-wrapper">
                                {item.answer}
                              </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        )}

        <div class="mt-20 p-8 md:p-12 bg-airtur-gray-light rounded-[3rem] border border-gray-100 flex flex-col sm:flex-row items-center sm:items-start gap-8 text-center sm:text-left relative overflow-hidden">
            <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-airtur-blue/5 rounded-full blur-3xl"></div>
            {authorData.avatar && (
              <div class="w-24 h-24 bg-white rounded-full overflow-hidden flex-shrink-0 border-4 border-white shadow-xl relative z-10">
                  <img src={authorData.avatar} alt={authorData.name} class="w-full h-full object-cover" />
              </div>
            )}
            <div class="relative z-10">
                <p class="text-[10px] text-airtur-blue font-black uppercase tracking-[0.3em] mb-2">Ekspert AirTUR</p>
                <p class="text-2xl font-black text-airtur-dark mb-3">{authorData.name}</p>
                <p class="text-base text-gray-600 font-medium leading-relaxed">{authorData.role}. {authorData.description}</p>
            </div>
        </div>

        <div class="mt-16 text-center">
            <a href="/baza-wiedzy" class="inline-flex items-center gap-3 bg-airtur-dark text-white px-8 py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-airtur-tech transition-all shadow-xl group">
               <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 group-hover:-translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0l7.5-7.5M3 12h18" /></svg>
               Powrót do Bazy Wiedzy
            </a>
        </div>
      </div>
    </div>
  </article>

  <button id="scroll-to-top" class="fixed bottom-10 right-10 z-50 flex items-center justify-center w-14 h-14 rounded-full bg-airtur-blue text-white shadow-2xl hover:bg-airtur-navy transition-all duration-300 opacity-0 translate-y-4 pointer-events-none group">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6 group-hover:-translate-y-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" /></svg>
  </button>
</Layout>

<style is:global>
  #content-col { will-change: grid-column, max-width; }

  /* Style stanów FAQ (Identyczne jak w Bazie Wiedzy) */
  .faq-item[data-state="open"] {
    border-color: #0ab3c6;
    background-color: rgba(240, 249, 255, 0.5);
  }

  .faq-item[data-state="open"] .icon-vertical {
    transform: rotate(90deg);
    opacity: 0;
  }

  .faq-highlight {
    animation: faqPulse 2.5s ease-out forwards;
  }

  @keyframes faqPulse {
    0% { background-color: rgba(10, 179, 198, 0.2); }
    100% { background-color: white; }
  }
</style>

<script>
  function initAirturEngine() {
    const sidebar = document.getElementById('sidebar-toc');
    const contentCol = document.getElementById('content-col');
    const openBtn = document.getElementById('toc-reopen-btn');
    const scrollBtn = document.getElementById('scroll-to-top');
    const DESKTOP_BP = 1024;

    // --- 1. LOGIKA UKŁADU (TOC + CENTROWANIE) ---
    const updateDesktopLayout = (isClosed) => {
      if (window.innerWidth < DESKTOP_BP) return;

      if (isClosed) {
        sidebar?.classList.add('lg:hidden');
        contentCol?.classList.replace('lg:col-span-8', 'lg:col-span-12');
        contentCol?.classList.add('max-w-4xl', 'mx-auto');
        
        openBtn?.classList.remove('lg:hidden', 'opacity-0', 'pointer-events-none');
        openBtn?.classList.add('lg:flex', 'opacity-100');
      } else {
        sidebar?.classList.remove('lg:hidden');
        contentCol?.classList.replace('lg:col-span-12', 'lg:col-span-8');
        contentCol?.classList.remove('max-w-4xl', 'mx-auto');
        
        openBtn?.classList.add('lg:hidden', 'opacity-0', 'pointer-events-none');
        openBtn?.classList.remove('lg:flex', 'opacity-100');
      }
    };

    window.addEventListener('toc-toggle', (e: any) => {
      const isClosing = e.detail.action === 'close';
      sessionStorage.setItem('toc_hidden_pref', isClosing ? 'true' : 'false');
      updateDesktopLayout(isClosing);
    });

    openBtn?.addEventListener('click', () => {
      sessionStorage.setItem('toc_hidden_pref', 'false');
      updateDesktopLayout(false);
    });

    if (sessionStorage.getItem('toc_hidden_pref') === 'true') updateDesktopLayout(true);

    // --- 2. LOGIKA FAQ (SYSTEM STANÓW) ---
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
      const toggle = item.querySelector('.faq-toggle');
      const answer = item.querySelector('.faq-answer');
      const wrapper = item.querySelector('.content-wrapper');

      toggle?.addEventListener('click', () => {
        const isOpen = item.getAttribute('data-state') === 'open';
        
        // Opcjonalnie: Zamknij inne (Single Open Mode)
        // faqItems.forEach(i => i !== item && closeFaq(i));

        if (isOpen) {
          item.setAttribute('data-state', 'closed');
          toggle.setAttribute('aria-expanded', 'false');
          (answer as HTMLElement).style.maxHeight = '0px';
        } else {
          item.setAttribute('data-state', 'open');
          toggle.setAttribute('aria-expanded', 'true');
          (answer as HTMLElement).style.maxHeight = `${wrapper.scrollHeight}px`;
          
          // Efekt Pulse (Focus)
          item.classList.add('faq-highlight');
          setTimeout(() => item.classList.remove('faq-highlight'), 2000);
        }
      });
    });

    // --- 3. SCROLL TO TOP ---
    window.addEventListener('scroll', () => {
      if (window.scrollY > 500) scrollBtn?.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
      else scrollBtn?.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
    });
    scrollBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }

  document.addEventListener('astro:page-load', initAirturEngine);
  initAirturEngine();
</script>