---
import Layout from '../layouts/Layout.astro';
import { companyConfig } from '../data/companyConfig';

// [LOGIKA]: Centralne zarządzanie datą i formatowaniem
const humanDate = companyConfig.dates.cookies;

const getMachineDate = (dateString: string) => {
  const months: { [key: string]: string } = {
    'stycznia': '01', 'lutego': '02', 'marca': '03', 'kwietnia': '04',
    'maja': '05', 'czerwca': '06', 'lipca': '07', 'sierpnia': '08',
    'września': '09', 'października': '10', 'listopada': '11', 'grudnia': '12'
  };
  const parts = dateString.split(' ');
  if (parts.length < 3) return "2026-01-01";
  const day = parts[0].padStart(2, '0');
  const month = months[parts[1].toLowerCase()] || '01';
  const year = parts[2];
  return `${year}-${month}-${day}`;
};

const machineDate = getMachineDate(humanDate);

// [STRUKTURA]: Spis treści
const sections = [
  { id: 'definicja', title: 'Czym są ciasteczka?' },
  { id: 'zastosowanie', title: 'Do czego ich używamy?' },
  { id: 'zarzadzanie', title: 'Zarządzanie plikami' },
];
---

<Layout 
  title="Polityka Cookies - AirTUR" 
  description="Informacje o wykorzystaniu plików cookies, narzędziach analitycznych i preferencjach użytkownika w serwisie AirTUR."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Polityka Cookies AirTUR",
    "lastReviewed": machineDate,
    "publisher": {
      "@type": "Organization",
      "name": companyConfig.name
    }
  })} />

  <main class="pt-32 pb-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <header class="mb-12 border-b border-gray-100 pb-10 text-center sm:text-left">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-airtur-blue/10 rounded-2xl mb-6 text-airtur-blue">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
          </svg>
        </div>
        <h1 class="text-4xl font-extrabold text-airtur-dark mb-4">Polityka Cookies</h1>
        <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500 italic">
          <span class="px-3 py-1 bg-airtur-blue/5 text-airtur-blue rounded-full not-italic font-medium">Transparentność danych</span>
          <span>Ostatnia aktualizacja: <time datetime={machineDate}>{humanDate} r.</time></span>
        </div>
      </header>

      <nav class="mb-16 p-6 bg-gray-50 rounded-2xl border border-gray-100" aria-label="Spis treści">
        <p class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-4">W tej sekcji</p>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-y-3 gap-x-8">
          {sections.map(section => (
            <li>
              <a href={`#${section.id}`} class="text-gray-600 hover:text-airtur-blue transition-colors flex items-center gap-2 group">
                <span class="w-1.5 h-1.5 rounded-full bg-airtur-blue/30 group-hover:bg-airtur-blue transition-colors"></span>
                {section.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="prose prose-blue prose-lg max-w-none text-gray-700 space-y-12">
        
        <section id="definicja" class="scroll-mt-32">
          <h2 class="text-2xl font-bold text-airtur-dark mb-4">Czym są ciasteczka?</h2>
          <p>
            Pliki cookies (tzw. „ciasteczka”) to małe dane informatyczne wysyłane przez nasz serwer i przechowywane w Twojej przeglądarce. Pozwalają one stronie „zapamiętać” Twoje działania i preferencje w określonym czasie, co sprawia, że korzystanie z serwisu jest płynniejsze i bardziej intuicyjne.
          </p>
        </section>

        <section id="zastosowanie" class="scroll-mt-32">
          <h2 class="text-2xl font-bold text-airtur-dark mb-6">Do czego ich używamy w {companyConfig.name}?</h2>
          <div class="grid grid-cols-1 gap-4">
            <div class="flex gap-5 p-6 rounded-2xl border border-gray-100 hover:border-airtur-blue/20 transition-colors">
              <div class="text-airtur-blue mt-1">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
              </div>
              <div>
                <h3 class="font-bold text-airtur-dark mb-1">Prawidłowe działanie</h3>
                <p class="text-sm text-gray-600">Nasz kalkulator mocy zapamiętuje wprowadzone dane podczas przechodzenia między krokami, dzięki czemu nie musisz ich wpisywać ponownie.</p>
              </div>
            </div>

            <div class="flex gap-5 p-6 rounded-2xl border border-gray-100 hover:border-airtur-blue/20 transition-colors">
              <div class="text-airtur-blue mt-1">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
              </div>
              <div>
                <h3 class="font-bold text-airtur-dark mb-1">Analiza ruchu</h3>
                <p class="text-sm text-gray-600">Korzystamy z anonimowej analityki, aby rozumieć, które poradniki w naszej Bazie Wiedzy są najchętniej czytane.</p>
              </div>
            </div>

            <div class="flex gap-5 p-6 rounded-2xl border border-gray-100 hover:border-airtur-blue/20 transition-colors">
              <div class="text-airtur-blue mt-1">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              </div>
              <div>
                <h3 class="font-bold text-airtur-dark mb-1">Twoje zgody</h3>
                <p class="text-sm text-gray-600">Zapamiętujemy, że zaakceptowałeś komunikaty prawne, abyśmy nie musieli wyświetlać Ci ich przy każdej wizycie.</p>
              </div>
            </div>
          </div>
        </section>

        <section id="zarzadzanie" class="scroll-mt-32">
          <div class="bg-airtur-blue/5 p-8 rounded-3xl border border-airtur-blue/10 relative overflow-hidden">
            <h2 class="text-2xl font-bold text-airtur-dark mb-4 mt-0 relative z-10">Zarządzanie plikami</h2>
            <p class="text-gray-700 relative z-10 mb-0 italic leading-relaxed">
              <strong>Pamiętaj:</strong> Możesz w dowolnym momencie wyłączyć lub ograniczyć obsługę ciasteczek w ustawieniach swojej przeglądarki. Należy jednak wiedzieć, że ich wyłączenie może wpłynąć na poprawność działania niektórych narzędzi interaktywnych (np. kalkulatora doboru pompy ciepła).
            </p>
          </div>
        </section>

        <footer class="mt-20 p-8 bg-airtur-dark rounded-3xl text-center text-white relative overflow-hidden">
          <div class="relative z-10">
            <h3 class="text-xl font-bold mb-2">Masz pytania dotyczące cookies?</h3>
            <p class="text-gray-400 mb-6 text-sm">Nasz zespół chętnie wyjaśni kwestie techniczne.</p>
            <a 
              href={companyConfig.contact.emailLink} 
              class="inline-block px-8 py-3 bg-airtur-blue hover:bg-white hover:text-airtur-dark font-bold rounded-full transition-all duration-300 shadow-lg shadow-airtur-blue/20"
            >
              {companyConfig.contact.email}
            </a>
          </div>
          <div class="absolute bottom-0 left-0 w-64 h-64 bg-airtur-blue/5 rounded-full -mb-32 -ml-32 blur-3xl"></div>
        </footer>

      </div>
    </div>
  </main>
</Layout>

<style>
  html { scroll-behavior: smooth; }
  /* Custom prose overrides for better legal reading */
  .prose h2 { margin-top: 0; }
</style>