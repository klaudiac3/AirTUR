---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { companyConfig } from '../../data/companyConfig';

export const prerender = true;

export async function getStaticPaths() {
  const caseEntries = await getCollection('cases');
  return caseEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;

// [SENIOR]: Renderowanie body (na wypadek gdybyś dopisała coś pod kreskami ---)
const { Content } = await entry.render();

// SEO & Metatagi
const seoTitle = d.seo?.meta_title || `${d.title} | Case Study AirTUR`;
const seoDesc = d.seo?.meta_description || d.tile_data.excerpt;

// [HELPER]: Mapowanie technologii z Twojego bogatego configu
const t = d.content.technology;
const techSpecs = [
  { label: 'System', value: t?.system },
  { label: 'Urządzenie', value: t?.brand },
  { label: 'Moc Grzewcza', value: typeof t?.heating_kw === 'number' ? `${t.heating_kw} kW` : t?.heating_kw },
  { label: 'SCOP', value: t?.scop, highlight: true },
  { label: 'Klasa Energ.', value: t?.energy_class_heating, bold: true },
  { label: 'Zakres pracy', value: t?.working_range },
  { label: 'Czynnik', value: t?.refrigerant },
  { label: 'Wi-Fi', value: t?.wifi_control ? 'TAK (W cenie)' : null },
].filter(item => item.value);

const sectionWrapper = "scroll-mt-24";
---

<Layout title={seoTitle} description={seoDesc}>
  
  <header class="bg-airtur-dark text-white pt-24 pb-12 md:pt-32 md:pb-16 relative overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-airtur-blue rounded-full blur-[120px] animate-pulse"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-6">
            <span class="bg-airtur-blue text-white text-[10px] font-black px-3 py-1 rounded-md uppercase tracking-[0.2em]">Case Study #{d.caseId}</span>
            <span class="text-gray-400 text-xs font-bold uppercase tracking-widest">{d.location}</span>
          </div>
          <h1 class="text-3xl md:text-5xl lg:text-6xl font-black leading-[1.1] tracking-tight text-balance">
            {d.title}
          </h1>
        </div>
        <div class="shrink-0">
          <div class="inline-block px-4 py-2 rounded-xl bg-white/5 border border-white/10 backdrop-blur-sm text-airtur-blue text-xs font-black uppercase tracking-widest">
            Kategoria: {d.category}
          </div>
        </div>
      </div>
    </div>
  </header>

  <main class="bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
        
        <div class="lg:col-span-7">
          
          <div class="rounded-3xl overflow-hidden shadow-2xl mb-12 border border-gray-100 aspect-video bg-gray-50">
            <img 
              src={d.image} 
              alt={d.title} 
              class="w-full h-full object-cover"
              loading="eager"
              fetchpriority="high"
            />
          </div>

          <article class="prose-airtur">
            
            <section id="problem" class={sectionWrapper}>
              <h2>{d.content.problem.heading}</h2>
              <p>{d.content.problem.description}</p>
              {d.content.problem.quote && (
                <div class="custom-quote-wrapper">
                  <blockquote>{d.content.problem.quote}</blockquote>
                </div>
              )}
            </section>

            <section id="rozwiazanie" class={sectionWrapper}>
              <h2>{d.content.solution.heading}</h2>
              <p>{d.content.solution.description}</p>
            </section>

            <Content />

            <section id="efekt" class={sectionWrapper}>
              <h2>{d.content.effect.heading}</h2>
              <div class="bg-emerald-50 border border-emerald-100 p-8 rounded-3xl relative overflow-hidden group">
                <div class="absolute -right-4 -bottom-4 opacity-10 text-emerald-600 transition-transform group-hover:scale-110">
                  <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                </div>
                <p class="text-gray-800 text-lg md:text-xl font-bold leading-relaxed relative z-10">
                  {d.content.effect.description}
                </p>
              </div>
            </section>
          </article>
        </div>

        <aside class="lg:col-span-5 space-y-8 lg:sticky lg:top-28">
          
          <div class="bg-airtur-dark text-white p-8 md:p-12 rounded-[2.5rem] shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 right-0 w-48 h-48 bg-emerald-500 opacity-10 rounded-full blur-[80px] -mr-24 -mt-24"></div>
            
            <div class="relative z-10">
              <span class="text-[10px] text-gray-400 font-black uppercase tracking-[0.3em] block mb-6">{d.roi_dashboard.roi_label}</span>
              <div class="text-6xl md:text-7xl font-black text-emerald-400 tracking-tighter mb-10">
                {d.roi_dashboard.value}
              </div>

              <div class="pt-8 border-t border-white/10">
                <span class="text-[10px] text-gray-400 font-black uppercase tracking-[0.3em] block mb-2">{d.roi_dashboard.time_label}</span>
                <div class="text-3xl font-black">{d.roi_dashboard.time}</div>
              </div>
            </div>
          </div>

          {techSpecs.length > 0 && (
            <div class="bg-white border border-gray-100 rounded-[2rem] p-8 shadow-xl">
              <h3 class="text-xs font-black text-gray-400 uppercase tracking-[0.2em] mb-8 border-b border-gray-50 pb-4">Specyfikacja techniczna</h3>
              <div class="space-y-4">
                {techSpecs.map(spec => (
                  <div class="flex justify-between items-end group">
                    <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">{spec.label}</span>
                    <div class="grow border-b border-dotted border-gray-200 mx-3 mb-1.5 opacity-40 group-hover:opacity-100 transition-opacity"></div>
                    <span class={`font-black text-sm ${spec.highlight ? 'text-airtur-blue' : 'text-airtur-dark'}`}>{spec.value}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <div class="bg-gray-50 rounded-[2rem] p-8 text-center border border-gray-100">
            <p class="text-xl font-black text-airtur-dark mb-6 text-balance">{d.roi_dashboard.ctaHeadline}</p>
            <a 
              href={d.roi_dashboard.ctaButtonLink} 
              class="w-full inline-flex items-center justify-center bg-airtur-blue text-white py-4 rounded-xl font-black text-xs tracking-widest uppercase hover:bg-airtur-navy transition-all duration-300 shadow-lg shadow-airtur-blue/20 active:scale-95"
            >
              {d.roi_dashboard.ctaButtonText}
            </a>
            <a href="/studia-przypadkow" class="inline-block mt-8 text-[10px] font-black text-gray-400 hover:text-airtur-blue uppercase tracking-widest transition-colors">
              ← Wróć do bazy analiz
            </a>
          </div>

        </aside>

      </div>
    </div>
  </main>
</Layout>
