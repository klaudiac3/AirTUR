---
// src/layouts/Layout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileStickyBar from '../components/MobileStickyBar.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { companyConfig } from '../data/companyConfig';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "AirTUR - Ekspercki montaż i serwis klimatyzacji, pomp ciepła oraz rekuperacji w Małopolsce.",
  image = "/og-image.jpg" 
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://airtur.pl');

// [LOGIKA]: Przygotowanie danych strukturalnych - teraz w 100% z konfigu
const schemaData = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": `AirTUR - ${companyConfig.fullName}`,
  "image": "https://airtur.pl/logo.png",
  "@id": "https://airtur.pl",
  "url": "https://airtur.pl",
  "telephone": companyConfig.contact.phoneFull,
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": companyConfig.address.street,
    "addressLocality": companyConfig.address.city,
    "postalCode": companyConfig.address.postCode,
    "addressRegion": "Małopolskie",
    "addressCountry": "PL"
  },
  "areaServed": companyConfig.seoServiceArea,
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": companyConfig.address.geo.latitude,
    "longitude": companyConfig.address.geo.longitude
  },
  // 🔥 DODANO: Inteligentna lista social mediów (z filtrowaniem pustych linków)
  "sameAs": Object.values(companyConfig.socials).filter(link => link !== ""),
  "openingHours": `Mo-Fr ${companyConfig.workingHours.weekdays}`,
  "description": "Specjaliści od inżynierii komfortu. Oferujemy fachowy montaż i autoryzowany serwis klimatyzacji oraz pomp ciepła."
};
---

<!doctype html>
<html lang="pl" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <link rel="icon" type="image/png" href="/favicon-96x96.png?v=2" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="shortcut icon" href="/favicon.ico?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <meta name="apple-mobile-web-app-title" content="AirTUR" />
    <link rel="manifest" href="/site.webmanifest?v=2" />
    <meta name="theme-color" content="#ffffff">
    
    <title>{title} | AirTUR</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | AirTUR`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL.origin)} />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </head>
  
  <body class="bg-white text-airtur-dark font-sans flex flex-col min-h-screen antialiased">
    
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:bg-airtur-blue focus:text-white focus:p-4">
      Skocz do treści głównej
    </a>

    <Header />

    <main id="main-content" class="flex-grow outline-none">
      <slot />
    </main>

    <Footer />
    <MobileStickyBar />
    <CookieBanner />

    <script is:inline>
      const fixOrphans = () => {
        const tags = ['p', 'h1', 'h2', 'h3', 'h4', 'li', 'span'];
        tags.forEach(tag => {
          const elements = document.querySelectorAll(tag);
          elements.forEach(el => {
            if (el.children.length === 0) {
              el.innerHTML = el.innerHTML.replace(/ ([aiouwz]) /gi, ' $1&nbsp;');
            }
          });
        });
      };
      window.addEventListener('DOMContentLoaded', fixOrphans);
      document.addEventListener('astro:page-load', fixOrphans);
    </script>
  </body>
</html>