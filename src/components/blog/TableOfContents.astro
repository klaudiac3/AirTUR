---
// [SENIOR NOTE]: Optimized TOC v2.2 - Auto-Scrolling Content Support
const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<nav 
  id="toc-container" 
  class="bg-gray-50 rounded-3xl border border-gray-200 transition-all duration-300 overflow-hidden"
  aria-label="Spis treści"
>
  <div 
    class="flex items-center justify-between p-5 border-b border-gray-200/50 cursor-pointer lg:cursor-default select-none" 
    id="toc-header-mobile"
  >
    <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 text-airtur-blue">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <span class="text-base lg:text-lg font-black text-airtur-dark uppercase tracking-tight">Spis treści</span>
    </div>
    
    <div class="flex items-center gap-3">
        <button 
          id="toc-close-btn-desktop" 
          class="hidden lg:flex items-center justify-center p-2 rounded-xl text-gray-400 hover:text-airtur-blue hover:bg-white transition-all duration-200 shadow-sm border border-transparent hover:border-gray-100"
          title="Schowaj i wyśrodkuj tekst"
        >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m18.75 4.5-7.5 7.5 7.5 7.5m-6-15L5.25 12l7.5 7.5" />
            </svg>
        </button>

        <button 
            id="toc-chevron-mobile"
            class="lg:hidden p-1 text-gray-400 transition-transform duration-300 -rotate-90"
        >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
        </button>
    </div>
  </div>
  
  <div id="toc-list-wrapper" class="overflow-hidden transition-[max-height] duration-500 ease-in-out max-h-0 lg:max-h-[70vh] lg:overflow-y-auto custom-scrollbar">
      <ul id="toc-list" class="space-y-1 px-6 pb-6 pt-2 lg:pt-6">
        {toc.map((heading) => (
          <li class={`${heading.depth === 3 ? 'ml-4 border-l border-gray-200 pl-4' : ''}`}>
            <a 
              href={`#${heading.slug}`} 
              class="toc-link block text-gray-600 hover:text-airtur-blue transition-all duration-200 py-1.5 leading-snug font-medium text-sm"
              data-target={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
  </div>
</nav>

<style>
  .custom-scrollbar::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #E5E7EB; border-radius: 20px; }
  
  .toc-link.active { 
    color: #0AB3C6;
    font-weight: 800;
  }

  @media (min-width: 1024px) {
    .toc-link.active { transform: translateX(6px); }
  }
</style>

<script>
  function setupTOC() {
    const wrapper = document.getElementById('toc-list-wrapper');
    const headerMobile = document.getElementById('toc-header-mobile');
    const chevron = document.getElementById('toc-chevron-mobile');
    const closeBtnDesktop = document.getElementById('toc-close-btn-desktop');
    const links = document.querySelectorAll('.toc-link');
    
    let isMobileOpen = false;

    // 1. Obsługa Mobile Toggle (Pozostaje bez zmian)
    const toggleMobile = (forceState = null) => {
        if (window.innerWidth >= 1024) return;
        isMobileOpen = forceState !== null ? forceState : !isMobileOpen;
        if (isMobileOpen) {
            wrapper.style.maxHeight = wrapper.scrollHeight + "px";
            chevron.style.transform = "rotate(0deg)";
        } else {
            wrapper.style.maxHeight = "0px";
            chevron.style.transform = "rotate(-90deg)";
        }
    };

    headerMobile?.addEventListener('click', (e) => {
        if (!e.target.closest('#toc-close-btn-desktop')) toggleMobile();
    });

    // 2. Desktop Close Event
    closeBtnDesktop?.addEventListener('click', (e) => {
        e.stopPropagation();
        window.dispatchEvent(new CustomEvent('toc-toggle', { detail: { action: 'close' } }));
    });

    // 3. Auto-Scroll i ScrollSpy (NAPRAWIONE)
    const observerOptions = {
      rootMargin: '-10% 0px -80% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          
          links.forEach(link => {
            const isActive = link.getAttribute('data-target') === id;
            link.classList.toggle('active', isActive);

            // KLUCZOWA POPRAWKA: Przewijaj spis treści, gdy link staje się aktywny
            if (isActive && window.innerWidth >= 1024) {
              // block: 'nearest' sprawia, że link "wskakuje" do widocznego obszaru nav, 
              // ale nie centruje go na siłę, co zapobiega drganiu strony.
              link.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
            }
          });
        }
      });
    }, observerOptions);

    document.querySelectorAll('h2, h3').forEach(h => observer.observe(h));

    // Zamykanie po kliknięciu (mobile)
    links.forEach(link => {
        link.addEventListener('click', () => {
            if (window.innerWidth < 1024) setTimeout(() => toggleMobile(false), 300);
        });
    });
  }

  document.addEventListener('astro:page-load', setupTOC);
  setupTOC();
</script>