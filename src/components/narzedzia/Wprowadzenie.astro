---
import { companyConfig } from '../../data/companyConfig';

/** * [KONFIGURACJA NARZĘDZIA]
 * Tutaj możesz błyskawicznie zmieniać wszystkie teksty i etapy.
 */
const toolConfig = {
  badge: "Inteligentny Dobór Klimatyzacji",
  title: "Centrum Kontroli",
  titleAccent: "Inwestycji",
  description: "Dopasuj idealne urządzenie i sprawdź potencjalne oszczędności w 4 prostych krokach.",
  
  // Lista kroków - możesz tu dopisywać lub zmieniać nazwy
  steps: [
    { id: 1, label: "Twoje Potrzeby" },
    { id: 2, label: "Dobór Mocy" },
    { id: 3, label: "Obecne Koszty" },
    { id: 4, label: "Podsumowanie" }
  ]
};

// Klasy CSS dla stanów (Style systemowe)
const activeNodeClass = "bg-airtur-blue text-white shadow-xl ring-4 ring-white";
const inactiveNodeClass = "bg-white text-gray-400 border-2 border-gray-100 shadow-sm ring-4 ring-white";
---

<section class="bg-white pt-6 md:pt-12 pb-10 border-b border-gray-100 relative z-20" aria-label="Narzędzie analizy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <header class="flex flex-col items-center justify-center text-center">
      <span class="inline-block px-3 py-1 mb-4 rounded-full bg-airtur-blue/10 text-airtur-blue text-[9px] font-black uppercase tracking-[0.2em]">
        {toolConfig.badge}
      </span>

      <div class="mb-8">
        <h1 class="text-xl md:text-3xl font-black text-airtur-dark tracking-tight uppercase whitespace-nowrap">
          {toolConfig.title} <span class="text-airtur-blue">{toolConfig.titleAccent}</span>
        </h1>
        <p class="text-[10px] md:text-xs text-gray-400 font-bold tracking-[0.15em] uppercase mt-1">
          {toolConfig.description}
        </p>
      </div>

      <div class="w-full max-w-4xl relative">
        
        <div class="absolute inset-0 bg-airtur-blue/5 rounded-[2.5rem] -mx-4 md:-mx-10 pointer-events-none border border-airtur-blue/5" aria-hidden="true"></div>
        
        <div class="relative z-10 py-10 px-4 md:px-16">
          
          <div class="absolute top-[50%] left-16 right-16 h-1 bg-gray-200 -translate-y-1/2 rounded-full" aria-hidden="true">
            <div 
              id="progress-line" 
              class="h-full bg-airtur-blue rounded-full transition-all duration-700 ease-out shadow-[0_0_15px_rgba(10,179,198,0.4)]" 
              style="width: 0%;"
            ></div>
          </div>

          <ol class="relative z-10 flex justify-between w-full list-none p-0 m-0">
            {toolConfig.steps.map((step, index) => (
              <li class="flex flex-col items-center" aria-current={index === 0 ? "step" : undefined}>
                <div class={`step-node w-10 h-10 md:w-12 md:h-12 rounded-full flex items-center justify-center font-black text-sm md:text-lg transition-all duration-500 ${index === 0 ? activeNodeClass : inactiveNodeClass}`}>
                  {step.id}
                </div>
                <span class={`step-label mt-3 text-[10px] md:text-xs font-black uppercase tracking-widest px-2 py-0.5 rounded ${index === 0 ? "text-airtur-dark bg-white/50" : "text-gray-400"}`}>
                  {step.label}
                </span>
              </li>
            ))}
          </ol>

        </div>
      </div>
    </header>
  </div>
</section>