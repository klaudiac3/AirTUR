const goals = [
  { id: "ogrzewanie", title: "Tanie Ogrzewanie", desc: "Chcę znacząco obniżyć rachunki zimą i w okresach przejściowych." },
  { id: "komfort", title: "Komfort Latem", desc: "Priorytetem jest szybkie chłodzenie w upalne dni." },
  { id: "zdrowie", title: "Zdrowie i Oczyszczanie", desc: "Mam alergię, zależy mi na jonizacji i filtracji powietrza." },
  { id: "cisza", title: "Cisza / Sypialnia", desc: "Urządzenie ma być niesłyszalne (spokojny sen)." },
  { id: "design", title: "Design Premium", desc: "Nowoczesny, matowy lub ciemny wygląd urządzenia." }
];
---

<div id="step-1" class="step-content transition-all duration-500 relative">
  
  <div class="text-center mb-10">
    <h2 class="text-2xl md:text-3xl font-black text-airtur-dark tracking-tight mb-3 uppercase">
      Krok 1: Twoje Potrzeby
    </h2>
    <p class="text-gray-500 font-medium text-sm md:text-base max-w-xl mx-auto leading-relaxed text-pretty">
      <span class="text-airtur-blue">Aby dobrać odpowiednią moc, musimy wiedzieć, w jakim otoczeniu będzie pracować Twoje urządzenie.</span>
    </p>
  </div>

  <div class="mb-12">
    <p class="text-[10px] md:text-xs font-black text-airtur-dark uppercase tracking-[0.2em] mb-6 opacity-80 flex items-center gap-2">
      <span class="w-6 h-6 rounded-full bg-airtur-blue/10 text-airtur-blue flex items-center justify-center">1</span>
      W jakim typie budynku znajduje się pomieszczenie?
    </p>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {buildingTypes.map((type) => (
        <button 
          type="button"
          class="type-btn group bg-white border-2 border-gray-100 rounded-[2rem] p-5 md:p-6 flex flex-col items-center justify-center transition-all duration-300 hover:border-airtur-blue hover:bg-airtur-blue/5 hover:shadow-2xl hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-airtur-blue/20" 
          data-value={type.id} 
          data-factor={type.factor}
        >
          <div class="w-14 h-14 rounded-2xl bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-airtur-blue group-hover:bg-white transition-all mb-4 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d={type.icon} />
            </svg>
          </div>
          <span class="font-black text-airtur-dark text-xs md:text-sm tracking-tight mb-1 group-hover:text-airtur-navy uppercase">{type.label}</span>
          <span class="text-[9px] text-gray-400 font-bold uppercase tracking-widest text-center leading-tight">{type.sub}</span>
        </button>
      ))}
    </div>
  </div>

  <div class="mb-2">
    <p class="text-[10px] md:text-xs font-black text-airtur-dark uppercase tracking-[0.2em] mb-6 opacity-80 flex items-center gap-2">
      <span class="w-6 h-6 rounded-full bg-airtur-blue/10 text-airtur-blue flex items-center justify-center">2</span>
      Jaki jest Twój najważniejszy cel?
    </p>
    
    <div class="grid grid-cols-1 gap-3 md:gap-4">
      {goals.map((goal) => (
        <button 
          type="button"
          class="goal-btn group w-full bg-white border-2 border-gray-100 rounded-[1.5rem] p-4 md:p-5 text-left transition-all duration-300 hover:border-airtur-blue hover:shadow-xl flex items-center gap-4 md:gap-5 hover:-translate-x-1 focus:outline-none" 
          data-goal={goal.id}
        >
          <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-gray-50 flex items-center justify-center text-gray-300 group-hover:text-airtur-blue group-hover:bg-white transition-all shrink-0 shadow-sm">
             <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
             </svg>
          </div>
          <div class="flex-grow">
            <span class="block font-black text-airtur-dark text-xs md:text-sm tracking-tight group-hover:text-airtur-navy transition-colors uppercase mb-0.5">
              {goal.title}:
            </span>
            <span class="text-[11px] md:text-xs text-gray-500 font-medium leading-relaxed block">
              {goal.desc}
            </span>
          </div>
          <div class="hidden md:block opacity-0 group-hover:opacity-100 transition-opacity text-airtur-blue pr-4">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5 animate-pulse">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </div>
        </button>
      ))}
    </div>
  </div>

</div>