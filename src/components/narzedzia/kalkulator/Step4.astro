---
// src/components/narzedzia/kalkulator/Step4.astro
---

<div id="step-4" class="hidden step-content transition-all duration-500 relative">
    
    <div class="relative flex items-center justify-center mb-10 min-h-[60px]">
        <div class="text-center">
            <h2 class="text-2xl md:text-3xl font-black text-airtur-dark tracking-tight uppercase leading-none">Krok 4: Wyniki i Raport</h2>
            <p class="text-gray-500 font-medium text-sm md:text-base max-w-xl mx-auto mt-2 leading-relaxed text-pretty">
                <span class="text-airtur-blue">Oto Twoja spersonalizowana prognoza finansowa i dobór sprzętu.</span>
            </p>
        </div>
        <button type="button" class="reset-btn absolute right-0 top-0 text-[10px] font-black text-gray-400 hover:text-red-500 uppercase tracking-widest border-b border-gray-200 transition-all cursor-pointer">
            Zacznij od nowa
        </button>
    </div>

    <div class="bg-airtur-dark rounded-[2rem] p-6 md:p-10 mb-12 text-white shadow-2xl relative overflow-hidden border border-white/10">
        <div class="absolute top-0 right-0 w-64 h-64 bg-airtur-blue opacity-20 rounded-full blur-[80px] -mr-16 -mt-16 pointer-events-none"></div>

        <h3 class="text-[10px] md:text-xs font-black uppercase tracking-[0.2em] text-center mb-8 opacity-60">
            Koszt wytworzenia <span class="text-airtur-blue">tej samej ilości ciepła</span>
        </h3>

        <div class="mb-10 space-y-6 max-w-2xl mx-auto relative z-10">
            <div>
                <div class="flex justify-between text-xs md:text-sm mb-2 opacity-80 font-medium">
                    <span>Twój obecny system</span>
                    <span id="cost-old" class="font-bold">0 zł</span>
                </div>
                <div class="w-full h-3 md:h-4 bg-gray-800 rounded-full overflow-hidden shadow-inner">
                    <div class="h-full bg-red-500 w-full opacity-80"></div> 
                </div>
            </div>
            <div>
                <div class="flex justify-between text-xs md:text-sm mb-2 font-bold text-airtur-blue">
                    <span>Klimatyzacja AirTUR</span>
                    <span id="cost-new">0 zł</span>
                </div>
                <div class="w-full h-3 md:h-4 bg-gray-800 rounded-full overflow-hidden shadow-inner relative">
                    <div id="bar-new" class="h-full bg-airtur-blue w-0 transition-all duration-1000 ease-out relative">
                        <div class="absolute inset-0 bg-white/20 w-full h-full animate-pulse"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="border-t border-white/10 pt-8 relative z-10">
            <p class="text-[10px] md:text-xs font-black uppercase tracking-[0.2em] text-airtur-blue mb-6 text-center">Prognoza Twoich Zysków</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center divide-y md:divide-y-0 md:divide-x divide-white/10">
                <div class="pb-4 md:pb-0 transition-transform hover:scale-105">
                    <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-1 font-bold">Rocznie</p>
                    <p class="text-2xl font-black text-green-400 tracking-tight"><span id="savings-year">0</span> zł</p>
                </div>
                <div class="py-4 md:py-0 transition-transform hover:scale-105">
                    <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-1 font-bold">Po 5 latach</p>
                    <p class="text-3xl font-black text-green-400 tracking-tight"><span id="savings-5years">0</span> zł</p>
                </div>
                <div class="pt-4 md:pt-0 transition-transform hover:scale-105">
                    <p class="text-[10px] uppercase tracking-widest text-airtur-blue mb-1 font-bold">Po 10 latach</p>
                    <p class="text-4xl font-black text-white tracking-tighter"><span id="savings-10years">0</span> zł</p>
                </div>
            </div>
            <p class="text-[9px] text-gray-500 mt-8 text-center uppercase tracking-wider">*Szacunek dla sezonu grzewczego przy zastąpieniu obecnego źródła.</p>
        </div>
    </div>

    <div class="mb-12">
        <p class="text-[10px] md:text-xs font-black text-airtur-dark uppercase tracking-[0.2em] mb-6 opacity-80 flex items-center justify-center gap-2">
            <span class="w-6 h-6 rounded-full bg-airtur-blue/10 text-airtur-blue flex items-center justify-center">!</span>
            Wybierz swój wariant
        </p>

        <div class="text-center max-w-3xl mx-auto px-4">
            <h3 id="transition-headline" class="text-xl md:text-2xl font-black text-airtur-dark mb-3 tracking-tight">Wynik jest jasny. Teraz wybierz komfort.</h3>
            <p id="transition-subtext" class="text-sm md:text-base text-gray-500 leading-relaxed font-medium mb-6">...</p>
            
            <div class="inline-flex flex-wrap justify-center items-center gap-2 text-xs text-gray-500 bg-airtur-blue/5 px-5 py-3 rounded-2xl border border-airtur-blue/10">
                <span>Zalecana moc: <strong id="summary-power" class="text-airtur-blue font-black text-sm">... kW</strong></span>
                <span class="text-gray-300">|</span>
                <span>Powierzchnia: <strong id="summary-area" class="text-airtur-dark font-bold">... m²</strong></span>
                <span class="text-gray-300 hidden md:inline">|</span>
                <span class="w-full md:w-auto mt-1 md:mt-0">Słońce: <strong id="summary-sun" class="text-airtur-dark font-bold">...</strong></span>
            </div>
        </div>
    </div>

    <div class="overflow-x-auto mb-16 -mx-4 sm:mx-0 pb-6 px-4 sm:px-0">
        <div class="min-w-[600px] max-w-4xl mx-auto">
            <div class="grid grid-cols-4 gap-2 sm:gap-4 text-sm relative mt-4 items-end">
                
                <div class="col-span-1 pb-4"></div>
                
                <div class="col-span-1 bg-gray-50 p-4 text-center rounded-t-2xl border-b-2 border-gray-200 flex flex-col justify-end min-h-[100px]">
                    <span class="text-xs font-black text-airtur-dark tracking-widest block mb-2">START</span>
                    <span class="text-[9px] bg-gray-200 text-gray-600 px-2.5 py-1 rounded-full inline-block font-bold tracking-widest">ECO</span>
                </div>

                <div class="col-span-1 bg-white rounded-t-2xl p-4 text-center border-t-4 border-airtur-blue shadow-[0_-10px_20px_-10px_rgba(0,0,0,0.1)] relative z-10 transform scale-105 origin-bottom flex flex-col justify-end min-h-[110px]">
                    <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-airtur-blue text-white text-[9px] px-3 py-1 rounded-full uppercase font-black tracking-widest whitespace-nowrap shadow-md">Ekspert Poleca</div>
                    <span class="text-xs font-black text-airtur-blue tracking-widest block mb-2">SMART</span>
                    <span class="text-[9px] bg-blue-50 text-airtur-blue px-2.5 py-1 rounded-full inline-block font-bold tracking-widest">ZŁOTY ŚRODEK</span>
                </div>

                <div class="col-span-1 bg-airtur-dark p-4 text-center rounded-t-2xl border-b-2 border-gray-800 flex flex-col justify-end min-h-[100px]">
                    <span class="text-xs font-black text-white tracking-widest block mb-2">PRO</span>
                    <span class="text-[9px] bg-gray-700 text-gray-300 px-2.5 py-1 rounded-full inline-block font-bold tracking-widest">PREMIUM</span>
                </div>

                <div class="col-span-1 flex items-center pl-2 text-xs font-bold text-gray-400 uppercase tracking-widest">Model</div>
                <div id="table-eco-name"     class="col-span-1 bg-gray-50 p-4 text-center text-[11px] font-bold text-airtur-dark">...</div>
                <div id="table-smart-name"   class="col-span-1 bg-white shadow-lg p-4 text-center text-[11px] font-black text-airtur-navy border-x border-gray-100 relative z-10 scale-105">...</div>
                <div id="table-premium-name" class="col-span-1 bg-airtur-navy p-4 text-center text-[11px] font-bold text-white">...</div>

                <div class="col-span-1 flex items-center pl-2 text-xs font-bold text-gray-400 uppercase tracking-widest">Energia</div>
                <div id="table-eco-energy"     class="col-span-1 bg-gray-50 p-4 text-center text-xs text-gray-600 font-medium">...</div>
                <div id="table-smart-energy"   class="col-span-1 bg-white shadow-lg p-4 text-center text-xs font-black text-airtur-blue border-x border-gray-100 relative z-10 scale-105">...</div>
                <div id="table-premium-energy" class="col-span-1 bg-airtur-navy p-4 text-center text-xs text-gray-300 font-medium">...</div>

                <div class="col-span-1 flex items-center pl-2 text-xs font-bold text-gray-400 uppercase tracking-widest">Głośność</div>
                <div id="table-eco-noise"     class="col-span-1 bg-gray-50 p-4 text-center text-xs text-gray-600 font-medium">...</div>
                <div id="table-smart-noise"   class="col-span-1 bg-white shadow-lg p-4 text-center text-xs font-black text-airtur-dark border-x border-gray-100 relative z-10 scale-105">...</div>
                <div id="table-premium-noise" class="col-span-1 bg-airtur-navy p-4 text-center text-xs text-white font-bold">...</div>

                <div class="col-span-1 flex items-center pl-2 text-xs font-bold text-gray-400 uppercase tracking-widest">Filtracja</div>
                <div id="table-eco-filter"     class="col-span-1 bg-gray-50 p-4 rounded-b-2xl text-center text-[10px] text-gray-500 leading-relaxed">...</div>
                <div id="table-smart-filter"   class="col-span-1 bg-white shadow-[0_10px_20px_-10px_rgba(0,0,0,0.1)] p-4 rounded-b-2xl text-center text-[10px] font-bold text-gray-600 border-x border-b border-gray-100 relative z-10 scale-105 leading-relaxed">...</div>
                <div id="table-premium-filter" class="col-span-1 bg-airtur-dark p-4 rounded-b-2xl text-center text-[10px] text-gray-400 leading-relaxed">...</div>
            </div>
        </div>
    </div>

    <div class="max-w-3xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
            
            <div class="relative group h-full">
                <div class="absolute inset-0 bg-airtur-blue/20 blur-xl rounded-[2rem] group-hover:bg-airtur-blue/40 transition-all duration-500"></div>
                <button id="cta-request-quote" type="button" class="relative w-full h-full bg-airtur-blue overflow-hidden text-white font-black p-6 md:p-8 rounded-[2rem] transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 active:scale-[0.98] flex flex-col items-center justify-center gap-3">
                    <span class="relative z-10 flex items-center justify-center gap-2 text-sm md:text-base uppercase tracking-[0.1em]">
                        Chcę darmową wycenę
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5 group-hover:translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                    </span>
                    <span class="relative z-10 text-[10px] md:text-xs font-medium opacity-90 leading-relaxed text-center normal-case tracking-normal">
                        Pobierz darmowe podsumowanie Twoich wyników, które przeanalizujemy i przygotujemy ofertę montażu (wymagany nr tel).
                    </span>
                    <div class="absolute inset-0 bg-airtur-navy translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"></div>
                </button>
            </div>

            <button id="cta-get-report" type="button" class="w-full h-full bg-white border-2 border-gray-100 text-airtur-dark p-6 md:p-8 rounded-[2rem] font-bold hover:border-airtur-blue/30 hover:bg-airtur-blue/5 transition-all shadow-sm transform hover:-translate-y-1 cursor-pointer flex flex-col items-center justify-center gap-3 group">
                <span class="text-sm md:text-base uppercase tracking-[0.1em] text-airtur-dark group-hover:text-airtur-blue transition-colors flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
                    Tylko raport PDF
                </span>
                <span class="text-[10px] md:text-xs font-medium text-gray-500 leading-relaxed text-center normal-case tracking-normal">
                    Pobierz darmowe podsumowanie Twoich wyników na swój adres e-mail.
                </span>
            </button>
        </div>
    </div>

    <div class="mt-12 text-center">
        <button type="button" class="back-btn text-[10px] font-black text-gray-400 hover:text-airtur-dark uppercase tracking-widest transition-colors flex items-center justify-center gap-2 mx-auto" data-prev="3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" /></svg>
            Wróć do Analizy
        </button>
    </div>

</div>