---
// src/components/narzedzia/kalkulator/Step3.astro

const HEAT_SOURCES = [
  { id: "electric", label: "Grzejniki Elektryczne", sub: "Mata / Piec akumulacyjny", icon: "M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" },
  { id: "coal_old", label: "Kocioł Węglowy", sub: "Starego typu / Drewno", icon: "M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" },
  { id: "pellet", label: "Ekogroszek / Pellet", sub: "Kocioł z podajnikiem", icon: "M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" },
  { id: "gas", label: "Gaz Ziemny", sub: "Kocioł kondensacyjny", icon: "M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zm0 15a5.25 5.25 0 110-10.5 5.25 5.25 0 010 10.5z" },
  { id: "oil", label: "Olej Opałowy", sub: "Własny zbiornik", icon: "M21.75 17.25v-.228a4.5 4.5 0 00-.12-1.03l-2.268-9.64a3.375 3.375 0 00-3.285-2.602H7.923a3.375 3.375 0 00-3.285 2.602l-2.268 9.64a4.5 4.5 0 00-.12 1.03v.228m19.5 0a3 3 0 01-3 3H5.25a3 3 0 01-3-3m19.5 0a3 3 0 00-3-3H5.25a3 3 0 00-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z" },
  { id: "district", label: "Ciepło Miejskie", sub: "Systemowy węzeł", icon: "M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21" }
];

const COMFORT_OPTIONS = [
  { val: "low", label: "Oszczędny", desc: "Mniej niż 20°C ze względu na koszty", icon: "M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" },
  { val: "standard", label: "Optymalny", desc: "Standardowa temperatura (ok. 21°C)", icon: "M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M3 12h2.25m.386-6.364l1.591-1.591M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z", isDefault: true },
  { val: "high", label: "Wysoki", desc: "Lubię ciepło, ponad 22°C w domu", icon: "M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" }
];
---

<div id="step-3" class="hidden step-content transition-all duration-500 relative">
  
  <div class="relative flex items-center justify-center mb-10 min-h-[60px]">
    <div class="text-center">
      <h2 class="text-2xl md:text-3xl font-black text-airtur-dark tracking-tight uppercase leading-none">Krok 3: Audyt Efektywności</h2>
      <p class="text-gray-500 font-medium text-sm md:text-base max-w-xl mx-auto mt-2 leading-relaxed text-pretty">
        <span class="text-airtur-blue">Obliczymy realne zapotrzebowanie energetyczne na podstawie Twoich rachunków.</span>
      </p>
    </div>
    <button type="button" class="reset-btn absolute right-0 top-0 text-[10px] font-black text-gray-400 hover:text-red-500 uppercase tracking-widest border-b border-gray-200 transition-all">
      Zacznij od nowa
    </button>
  </div>

  <div class="max-w-5xl mx-auto bg-airtur-blue/5 border border-airtur-blue/10 rounded-[1.5rem] py-6 px-5 md:py-8 md:px-10 mb-12 transition-all hover:shadow-sm">
    <p class="text-[10px] md:text-xs font-black text-airtur-dark uppercase tracking-[0.2em] mb-8 opacity-80 flex items-center gap-2">
      <span class="w-6 h-6 rounded-full bg-airtur-blue/10 text-airtur-blue flex items-center justify-center">1</span>
      Miesięczny koszt ogrzewania (w sezonie)
    </p>

    <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12">
      <div class="flex items-center shrink-0">
        <div class="relative group">
          <input type="number" id="bill-input" value="800" min="100" max="5000" step="50" class="w-24 md:w-28 bg-white border-2 border-airtur-blue/20 rounded-xl px-2 py-2 text-2xl font-black text-airtur-navy text-center focus:outline-none focus:ring-4 focus:ring-airtur-blue/10 transition-all">
        </div>
        <span class="ml-3 text-xs font-black text-airtur-dark uppercase opacity-60">zł</span>
      </div>

      <div class="flex-grow w-full relative">
        <div class="relative flex items-center h-6">
          <input type="range" id="bill-slider" min="100" max="5000" step="50" value="800" class="custom-slider w-full h-1.5 bg-gray-200 rounded-full appearance-none cursor-pointer transition-all">
        </div>
        <div class="relative w-full h-8 mt-2">
          <span class="absolute left-0 text-[9px] font-bold text-gray-400 uppercase">100 zł</span>
          <span class="absolute right-0 text-[9px] font-bold text-gray-400 uppercase">5000+ zł</span>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-4 border-t border-airtur-blue/10 text-center">
      <p class="text-[10px] md:text-[11px] text-gray-400 font-medium leading-tight uppercase tracking-wide">
        System automatycznie przeliczy kwotę na efektywną energię cieplną w budynku.
      </p>
    </div>
  </div>

  <div class="mb-12">
    <p class="text-[10px] md:text-xs font-black text-airtur-dark uppercase tracking-[0.2em] mb-6 opacity-80 flex items-center gap-2">
      <span class="w-6 h-6 rounded-full bg-airtur-blue/10 text-airtur-blue flex items-center justify-center">2</span>
      Obecne źródło ogrzewania
    </p>
    
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {HEAT_SOURCES.map((fuel) => (
        <button 
          type="button"
          class="heat-btn group bg-white border-2 border-gray-100 rounded-[2rem] p-5 flex flex-col items-center justify-center transition-all duration-300 hover:border-airtur-blue hover:bg-airtur-blue/5 hover:shadow-xl hover:-translate-y-1 focus:outline-none" 
          data-fuel={fuel.id}
        >
          <div class="w-12 h-12 rounded-2xl bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-airtur-blue group-hover:bg-white transition-all mb-4 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d={fuel.icon} />
            </svg>
          </div>
          <span class="font-black text-airtur-dark text-xs md:text-sm tracking-tight mb-1 group-hover:text-airtur-navy uppercase text-center">{fuel.label}</span>
          <span class="text-[8px] md:text-[9px] text-gray-400 font-bold uppercase tracking-widest text-center leading-tight">{fuel.sub}</span>
        </button>
      ))}
    </div>
  </div>

  <div class="mb-14">
    <p class="text-[10px] md:text-xs font-black text-airtur-dark uppercase tracking-[0.2em] mb-6 opacity-80 flex items-center gap-2">
      <span class="w-6 h-6 rounded-full bg-airtur-blue/10 text-airtur-blue flex items-center justify-center">3</span>
      Obecny komfort cieplny w pomieszczeniu
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {COMFORT_OPTIONS.map((opt) => (
        <label class="group cursor-pointer">
          <input type="radio" name="comfort" value={opt.val} class="peer sr-only" checked={opt.isDefault}>
          <div class="h-full bg-white border-2 border-gray-100 rounded-[2rem] p-6 flex flex-col items-center justify-center transition-all duration-300 peer-checked:border-airtur-blue peer-checked:bg-airtur-blue/5 peer-checked:shadow-xl hover:border-airtur-blue/30 hover:-translate-y-1">
            <div class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-airtur-blue mb-3 shadow-sm peer-checked:bg-white">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d={opt.icon} />
              </svg>
            </div>
            <span class="font-black text-airtur-dark text-xs uppercase group-hover:text-airtur-navy mb-1">{opt.label}</span>
            <span class="text-[9px] text-gray-400 font-bold uppercase tracking-widest text-center">{opt.desc}</span>
          </div>
        </label>
      ))}
    </div>
  </div>

  <div class="max-w-md mx-auto relative group mb-16">
    <div class="absolute inset-0 bg-airtur-blue/20 blur-2xl rounded-[2rem] group-hover:bg-airtur-blue/40 transition-all duration-500"></div>
    <button id="roi-btn" type="button" class="relative w-full bg-airtur-blue overflow-hidden text-white font-black py-5 rounded-[2rem] transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 active:scale-[0.98] uppercase tracking-[0.2em] text-[11px] md:text-xs">
      <span class="relative z-10 flex items-center justify-center gap-3">
        Przeprowadź analizę oszczędności
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 group-hover:translate-x-1 transition-transform">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
      </span>
      <div class="absolute inset-0 bg-airtur-navy translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"></div>
    </button>
  </div>

  <div class="mt-12 text-center">
    <button type="button" class="back-btn text-[10px] font-black text-gray-400 hover:text-airtur-dark uppercase tracking-widest transition-colors flex items-center justify-center gap-2 mx-auto" data-prev="2">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
      </svg>
      Wróć do Doboru Mocy
    </button>
  </div>

</div>