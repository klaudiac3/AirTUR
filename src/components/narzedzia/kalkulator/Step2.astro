---
// [KONFIGURACJA]: Dane techniczne i teksty
import { TIERS } from './models.js';

const SUN_OPTIONS = [
  { val: "0.08", label: "Niski", sub: "Okna północne / Cień", iconPath: "M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M3 12h2.25m.386-6.364 1.591-1.591M12 18.75V21" },
  { val: "0.10", label: "Średni", sub: "Okna wschodnie / zachodnie", iconPath: "M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M3 12h2.25m.386-6.364 1.591-1.591M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z", isDefault: true },
  { val: "0.13", label: "Wysoki", sub: "Okna południowe / Przeszklenia", isSpecial: true }
];

const PEOPLE_OPTIONS = [
  { val: "0", label: "1-2 osoby", iconPath: "M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z", isDefault: true },
  { val: "0.3", label: "3-4 osoby", iconPath: "M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94-3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" },
  { val: "0.6", label: "5+ osób", iconPath: "M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" }
];
---

<div id="step-2" class="hidden step-content transition-all duration-500 relative">
  
  <div class="relative flex items-center justify-center mb-10 min-h-[60px]">
    <div class="text-center">
      <h2 class="text-2xl md:text-3xl font-black text-airtur-dark tracking-tight uppercase leading-none">Krok 2: Dobór Mocy</h2>
      <p class="text-gray-500 font-medium text-sm md:text-base max-w-xl mx-auto mt-2 leading-relaxed text-pretty">
        <span class="text-airtur-blue">Aby dobrać odpowiednią moc, musimy wiedzieć, w jakim otoczeniu będzie pracować Twoje urządzenie.</span>
      </p>
    </div>
    <button type="button" class="reset-btn absolute right-0 top-0 text-[10px] font-black text-gray-400 hover:text-red-500 uppercase tracking-widest border-b border-gray-200 transition-all">
      Zacznij od nowa
    </button>
  </div>

  <div class="max-w-5xl mx-auto bg-airtur-blue/5 border border-airtur-blue/10 rounded-[1.5rem] py-6 px-5 md:py-8 md:px-10 mb-12 transition-all hover:shadow-sm">
    <p class="text-[10px] md:text-xs font-black text-airtur-dark uppercase tracking-[0.2em] mb-8 opacity-80 flex items-center gap-2">
      <span class="w-6 h-6 rounded-full bg-airtur-blue/10 text-airtur-blue flex items-center justify-center">1</span>
      Jaką powierzchnię chcesz obsłużyć urządzeniem?
    </p>

    <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12">
      <div class="flex items-center shrink-0">
        <div class="relative group">
          <input type="number" id="area-input" value="25" min="10" max="500" class="w-24 bg-white border-2 border-airtur-blue/20 rounded-xl px-2 py-2 text-2xl font-black text-airtur-navy text-center focus:outline-none focus:ring-4 focus:ring-airtur-blue/10 transition-all">
        </div>
        <span class="ml-3 text-xs font-black text-airtur-dark uppercase opacity-60">m²</span>
      </div>

      <div class="flex-grow w-full relative">
        <div class="relative flex items-center h-6">
          <input type="range" id="area-slider" min="10" max="500" value="25" class="custom-slider w-full h-1.5 bg-gray-200 rounded-full appearance-none cursor-pointer transition-all">
        </div>
        <div class="relative w-full h-8 mt-2">
          <span class="absolute left-0 text-[9px] font-bold text-gray-300 uppercase">10 m²</span>
          <div id="optimal-marker" class="absolute left-[3.06%] flex flex-col items-center -translate-x-1/2">
             <div class="w-px h-2 bg-airtur-blue/40 mb-1"></div>
             <span class="text-[8px] font-black text-airtur-blue uppercase tracking-tighter whitespace-nowrap bg-white px-2 py-1 rounded border border-airtur-blue/10 shadow-sm">Optymalnie: 25-45 m²</span>
          </div>
          <span class="absolute right-0 text-[9px] font-bold text-gray-300 uppercase">500 m²</span>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-4 border-t border-airtur-blue/10 text-center">
      <p class="text-[10px] md:text-[11px] text-gray-400 font-medium leading-tight uppercase tracking-wide">
        Jeśli chcesz schłodzić tylko <strong>salon</strong>, wpisz jego metraż (np. 25 m²).<br>
        Jeśli planujesz system na <strong>całe mieszkanie</strong>, wpisz łączny metraż.
      </p>
    </div>
  </div>

  <div class="mb-12">
    <p class="text-[10px] md:text-xs font-black text-airtur-dark uppercase tracking-[0.2em] mb-6 opacity-80 flex items-center gap-2">
      <span class="w-6 h-6 rounded-full bg-airtur-blue/10 text-airtur-blue flex items-center justify-center">2</span>
      Poziom nasłonecznienia pomieszczenia
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {SUN_OPTIONS.map((opt) => (
        <label class="group cursor-pointer">
          <input type="radio" name="sun" value={opt.val} class="peer sr-only" checked={opt.isDefault}>
          <div class="h-full bg-white border-2 border-gray-100 rounded-[2rem] p-6 flex flex-col items-center justify-center transition-all duration-300 peer-checked:border-airtur-blue peer-checked:bg-airtur-blue/5 peer-checked:shadow-xl hover:border-airtur-blue/30 hover:-translate-y-1">
            <div class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-airtur-blue mb-3 shadow-sm peer-checked:bg-white">
              {opt.isSpecial ? (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-yellow-400 group-hover:animate-pulse"><path d="M12 2.25a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75ZM7.5 12a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM18.894 5.166a.75.75 0 0 0-1.06-1.06l-1.591 1.59a.75.75 0 1 0 1.06 1.061l1.591-1.59ZM21.75 12a.75.75 0 0 1-.75.75h-2.25a.75.75 0 0 1 0-1.5H21a.75.75 0 0 1 .75.75ZM17.834 18.894a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 1 0-1.061 1.06l1.59 1.591ZM12 18.75a.75.75 0 0 1 .75.75V21.75a.75.75 0 0 1-1.5 0V19.5a.75.75 0 0 1 .75-.75ZM5.166 18.894a.75.75 0 0 1-1.06-1.06l1.59-1.591a.75.75 0 0 1 1.061 1.06l-1.59 1.591ZM3 12a.75.75 0 0 1 .75-.75H6a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 12ZM5.166 5.166a.75.75 0 0 1 1.06 1.06L4.635 7.817a.75.75 0 1 1-1.06-1.06l1.591-1.591Z" /></svg>
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d={opt.iconPath} /></svg>
              )}
            </div>
            <span class="font-black text-airtur-dark text-xs uppercase group-hover:text-airtur-navy">{opt.label}</span>
            <span class="text-[8px] text-gray-400 font-bold uppercase tracking-widest text-center">{opt.sub}</span>
          </div>
        </label>
      ))}
    </div>
    <p id="sun-desc" class="mt-3 text-sm text-gray-500 italic text-center">Okna od zachodu, standardowe mieszkanie, brak rolet zewnętrznych.</p>
  </div>

  <div class="mb-12">
    <p class="text-[10px] md:text-xs font-black text-airtur-dark uppercase tracking-[0.2em] mb-6 opacity-80 flex items-center gap-2">
      <span class="w-6 h-6 rounded-full bg-airtur-blue/10 text-airtur-blue flex items-center justify-center">3</span>
      Stała liczba osób w pomieszczeniu
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {PEOPLE_OPTIONS.map((opt) => (
        <label class="group cursor-pointer">
          <input type="radio" name="people" value={opt.val} class="peer sr-only" checked={opt.isDefault}>
          <div class="h-full bg-white border-2 border-gray-100 rounded-[2rem] p-6 flex flex-col items-center justify-center transition-all duration-300 peer-checked:border-airtur-blue peer-checked:bg-airtur-blue/5 peer-checked:shadow-xl hover:border-airtur-blue/30 hover:-translate-y-1">
            <div class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center text-gray-400 group-hover:text-airtur-blue mb-3 shadow-sm peer-checked:bg-white">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d={opt.iconPath} /></svg>
            </div>
            <span class="font-black text-airtur-dark text-xs uppercase group-hover:text-airtur-navy">{opt.label}</span>
          </div>
        </label>
      ))}
    </div>
    <p class="mt-3 text-sm text-gray-500 italic text-center">Każda osoba to "grzejnik" (ok. 100W), który urządzenie musi zneutralizować.</p>
  </div>

  <div class="max-w-md mx-auto relative group mb-16">
    <div class="absolute inset-0 bg-airtur-blue/20 blur-2xl rounded-[2rem] group-hover:bg-airtur-blue/40 transition-all duration-500"></div>
    <button id="calculate-btn" class="relative w-full bg-airtur-blue overflow-hidden text-white font-black py-5 rounded-[2rem] transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 active:scale-[0.98] uppercase tracking-[0.2em] text-xs">
      <span class="relative z-10 flex items-center justify-center gap-3">
        Oblicz potrzebną moc
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 group-hover:translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
      </span>
      <div class="absolute inset-0 bg-airtur-navy translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"></div>
    </button>
  </div>

  <div id="intermediate-result" class="hidden animate-fade-in mt-12">
    <div class="bg-airtur-blue/5 border-2 border-airtur-blue rounded-[2.5rem] p-8 text-center mb-12 relative overflow-hidden">
      <p class="text-[10px] md:text-xs font-black text-airtur-dark uppercase tracking-[0.2em] mb-4 opacity-80 flex items-center justify-center gap-2">Twoje zapotrzebowanie:</p>
      <p class="text-5xl md:text-6xl font-black text-airtur-dark mb-2 tracking-tighter">
        <span id="temp-result-power">0.0</span> <span class="text-2xl">kW</span>
      </p>
      <p class="text-gray-500 text-[11px] md:text-xs font-medium uppercase tracking-widest opacity-70">Na podstawie powierzchni, nasłonecznienia i osób.</p>
    </div>

    <div class="mb-14 text-center">
      <h2 class="text-2xl md:text-3xl font-black text-airtur-dark tracking-tight uppercase leading-none">Oto 3 strategie doboru urządzenia dla Ciebie:</h2>
      <p class="text-sm md:text-base text-gray-500 max-w-xl mx-auto leading-relaxed font-medium text-pretty">Wybierz opcję dopasowaną do Twojego budżetu i wymagań.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
      {Object.values(TIERS).map((tier) => (
        <div id={`card-${tier.id}`} class={`relative flex flex-col rounded-2xl border-2 ${tier.borderColor} ${tier.bgColor} ${tier.highlight ? 'scale-105 z-10 shadow-xl' : ''} overflow-hidden transition-transform hover:-translate-y-1 hover:shadow-lg cursor-pointer`}>
          <div class={`${tier.badgeColor} text-white text-xs font-bold uppercase py-2 text-center tracking-wider`}>{tier.label}</div>
          <div class="p-6 flex-grow flex flex-col">
            <h4 id={`model-${tier.id}-name`} class={`text-lg font-bold ${tier.textColor} mb-1 leading-tight min-h-[3rem]`}>Model...</h4>
            <p class={`text-xs ${tier.taglineColor || 'text-gray-500'} italic mb-4`}>{tier.tagline}</p>
            <div class="mt-auto space-y-3">
              {['price', 'tech'].map(type => (
                <div class="flex justify-between items-center text-sm">
                  <span class={`${tier.isDarkTheme ? 'text-gray-300' : 'text-gray-600'} font-medium`}>{type === 'price' ? 'Cena' : 'Technologia'}</span>
                  <div class="flex gap-1">
                    {[1, 2, 3, 4, 5].map(dot => (
                      <span class={`w-2.5 h-2.5 rounded-full ${dot <= tier.indicators[type] ? (tier.isDarkTheme ? 'bg-airtur-blue' : tier.badgeColor) : 'bg-gray-300'}`}></span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
            <div class={`mt-4 pt-4 border-t ${tier.isDarkTheme ? 'border-gray-700' : 'border-gray-200'}`}>
              <p id={`model-${tier.id}-desc`} class={`text-xs ${tier.isDarkTheme ? 'text-gray-400' : 'text-gray-600'} leading-relaxed`}>Opis...</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center">
      <p class="text-gray-600 mb-4 font-medium max-w-2xl mx-auto">Każdy z tych modeli spełni Twoje zapotrzebowanie. Teraz sprawdźmy, ile pieniędzy zaoszczędzisz na ogrzewaniu.</p>
      <div class="max-w-md mx-auto relative group mb-16">
        <div class="absolute inset-0 bg-airtur-blue/20 blur-2xl rounded-[2rem] group-hover:bg-airtur-blue/40 transition-all duration-500"></div>
        <button id='go-to-roi-btn' class="relative w-full bg-airtur-blue overflow-hidden text-white font-black py-5 rounded-[2rem] transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 active:scale-[0.98] uppercase tracking-[0.2em] text-xs">
      <span class="relative z-10 flex items-center justify-center gap-3">
        PRZEJDŹ DO KALKULATORA OSZCZĘDNOŚCI (ROI)
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 group-hover:translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
      </span>
      <div class="absolute inset-0 bg-airtur-navy translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"></div>
    </button>
      </div>
    </div>
  </div>

  <div class="mt-12 text-center">
    <button type="button" class="back-btn text-[10px] font-black text-gray-400 hover:text-airtur-dark uppercase tracking-widest transition-colors flex items-center justify-center gap-2 mx-auto" data-prev="1">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" /></svg>
      Wróć do potrzeb
    </button>
  </div>
</div>

<style>
  .custom-slider::-webkit-slider-thumb {
    appearance: none; width: 24px; height: 24px; background: #ffffff;
    border: 4px solid #0ab3c6; border-radius: 50%; cursor: pointer;
    box-shadow: 0 4px 12px rgba(10, 179, 198, 0.3); transition: all 0.2s ease;
    z-index: 30; position: relative;
  }
  .custom-slider::-webkit-slider-thumb:hover { transform: scale(1.2); background: #0ab3c6; }
  .animate-fade-in { animation: fadeIn 0.6s ease-out forwards; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>