---
import { companyConfig } from '../../data/companyConfig';
---

<section class="bg-white pt-12 pb-16 md:pb-24 border-t border-gray-100" aria-label="Obszar działania">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-black text-airtur-dark mb-6 tracking-tight leading-[1.1]">
        Gdzie działamy? <br class="hidden md:inline" />
        <span class="text-airtur-blue">Cała Małopolska i sąsiednie regiony.</span>
      </h2>
      <p class="text-base md:text-lg text-gray-500 leading-relaxed max-w-4xl mx-auto text-pretty">
        Nasza ekipa jest mobilna i dostępna w całym województwie. Niezależnie od tego, czy mieszkasz w centrum Krakowa, w domku pod lasem w Limanowej, czy na osiedlu w Tarnowie – gwarantujemy ten sam, wysoki standard obsługi.
        <br><br>
        Bazą operacyjną AirTUR jest <span class="text-airtur-dark font-bold">{companyConfig.address.city}</span>, ale obsługujemy klientów w promieniu ok. 200 km, realizując montaże również na Podkarpaciu i Śląsku.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12 mb-20">
      {companyConfig.serviceAreas.map((area, index) => (
        <div class="bg-gray-50 p-8 rounded-3xl border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col group">
          <div class="flex items-center gap-4 mb-8">
            <div class="p-3 bg-white shadow-sm rounded-2xl text-airtur-blue group-hover:bg-airtur-blue group-hover:text-white transition-colors duration-300">
                {index === 0 && (
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                  </svg>
                )}
                {index === 1 && (
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                  </svg>
                )}
                {index >= 2 && (
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-10.5V15m-9 3.75h.008v.008H6V18.25Zm3 0h.008v.008H9V18.25Zm3 0h.008v.008H12V18.25Zm3 0h.008v.008H15V18.25Zm3 0h.008v.008H18V18.25Zm-9-7.5h.008v.008H9V10.75Zm3 0h.008v.008H12V10.75Zm3 0h.008v.008H15V10.75Z" />
                  </svg>
                )}
            </div>
            <h3 class="text-xl font-black text-airtur-dark tracking-tight">{area.region}</h3>
          </div>
          
          <ul class="space-y-4 flex-grow">
            {area.places.map((place) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-airtur-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-gray-600 leading-snug">
                  <strong class="text-airtur-dark font-bold">{place.label}:</strong> {place.desc}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="text-center max-w-5xl mx-auto">
        <div class="w-full h-[350px] md:h-[500px] bg-gray-100 rounded-[2rem] overflow-hidden shadow-2xl border border-gray-100 mb-12 md:mb-16">
            <iframe 
                src="https://www.google.com/maps/d/embed?mid=1YWobGZr-DNoQTrPPtaiyQv9JLUdgPOs" 
                width="100%" 
                height="100%" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade"
                title="Mapa zasięgu AirTUR"
            ></iframe>
        </div>

        <div class="max-w-3xl mx-auto">
          <h3 class="text-2xl md:text-4xl font-black text-airtur-dark mb-4 tracking-tight italic">Nie widzisz swojego miasta?</h3>
          <p class="text-base md:text-lg text-gray-500 leading-relaxed mb-10 text-pretty">
              Powyższy wykaz to nasze najczęstsze trasy, ale nie jedyne. Jeśli mieszkasz w innej miejscowości w promieniu do 200 km od {companyConfig.address.city} – zadzwoń. Dojedziemy.
          </p>
          
          <button 
            onclick="window.scrollTo({ top: 0, behavior: 'smooth' });" 
            class="inline-flex items-center text-lg md:text-xl font-black text-airtur-blue hover:text-airtur-navy border-b-4 border-airtur-blue/30 hover:border-airtur-navy transition-all duration-300 pb-2 cursor-pointer group"
          >
            ZAPYTAJ O DOJAZD 
            <span class="ml-3 transform group-hover:translate-x-2 transition-transform">→</span>
          </button>
        </div>
    </div>
  </div>
</section>