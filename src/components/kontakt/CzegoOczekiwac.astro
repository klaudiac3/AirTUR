---
// [DATA]: Tutaj zarządzasz treścią. Łatwo dodasz czwartą kartę lub zmienisz opisy.
const expectations = [
  {
    title: "Kontakt w 24h",
    description: "Szanujemy Twój czas. Nasz Ekspert skontaktuje się z Tobą najpóźniej w kolejnym dniu roboczym.",
    iconPath: "M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z",
    rotateClass: "-rotate-3"
  },
  {
    title: "Dobór Parametrów",
    description: "Korzystając z naszych narzędzi możesz wyliczyć szacowany zwrot z inwestycji oraz dobrać moc urządzenia pod Twój budynek.",
    iconPath: "M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V13.5Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V18Zm2.498-6.75h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V13.5Zm0 2.25h.007v.008h-.007v-.008Zm0 2.25h.008v.008h-.008V18Zm2.504-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5ZM6.375 5.457c.003-.538.042-1.178.168-1.668.293-1.145 1.385-2.036 2.563-2.036h7.788c1.178 0 2.27.89 2.563 2.036.126.49.165 1.13.168 1.668h-13.25Zm0 0v15.086c0 1.178.89 2.27 2.036 2.564.49.125 1.13.164 1.668.167h7.788c.538-.003 1.178-.042 1.668-.167 1.146-.293 2.036-1.386 2.036-2.564V5.457h-13.25Z",
    rotateClass: "rotate-3"
  },
  {
    title: "Jasna Wycena",
    description: "Otrzymasz od Nas konkretną ofertę. Bez gwiazdek, bez dopłat na miejscu, bez ukrytych kosztów.",
    iconPath: "M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z",
    rotateClass: "-rotate-3"
  }
];
---

<section class="relative bg-white py-12 md:py-16 overflow-hidden">
  <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-full max-h-[550px] bg-airtur-blue/5 md:bg-airtur-blue/10 pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-4xl mx-auto text-center mb-12">
      <h3 class="text-2xl md:text-3xl font-black text-airtur-dark tracking-tight">
        Po wysłaniu zgłoszenia <span class="text-airtur-blue">możesz liczyć na:</span>
      </h3>
    </div>
      
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {expectations.map((item) => (
        <article class="group bg-white p-8 rounded-3xl shadow-lg border border-airtur-blue/5 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl flex flex-col items-center text-center">
          
          <div class={`w-20 h-20 rounded-2xl bg-white shadow-sm border border-gray-100 flex items-center justify-center mb-6 text-airtur-blue transition-transform duration-500 group-hover:scale-110 group-hover:${item.rotateClass}`}>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.iconPath} />
            </svg>
          </div>

          <h4 class="font-black text-lg text-airtur-dark mb-3 tracking-tight">
            {item.title}
          </h4>

          <p class="text-sm text-gray-500 leading-relaxed font-medium">
            {item.description}
          </p>

        </article>
      ))}
    </div>

  </div>
</section>