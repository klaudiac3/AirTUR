---
import { companyConfig } from '../../data/companyConfig';
---

<section class="pt-8 pb-12 md:pb-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="grid grid-cols-1 lg:grid-cols-5 bg-white shadow-2xl rounded-3xl overflow-hidden">
      
      <div class="lg:col-span-3 p-8 md:p-12 lg:p-16">
        
        <h2 class="text-3xl font-black text-airtur-dark mb-8 tracking-tight">Formularz Kontaktowy</h2>
        
        <form 
          id="main-contact-form"
          name="kontakt-glowny" 
          method="POST" 
          class="space-y-6"
          novalidate
        >
          <div class="hidden" aria-hidden="true">
            <input type="text" name="b_website" tabindex="-1" value="" autocomplete="off" />
          </div>

          <input type="hidden" name="form-name" value="kontakt-glowny" />
          <input type="hidden" name="source" value="strona_kontaktowa_glowna" />
          <input type="hidden" name="cel" value="kontakt" />
          
          <div>
            <label for="name" class="block text-sm font-bold text-gray-700 mb-1">Imię i Nazwisko <span class="text-airtur-blue">*</span></label>
            <input type="text" id="name" name="imie" required 
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-airtur-blue focus:ring-4 focus:ring-airtur-blue/20 outline-none transition bg-white" 
              placeholder="Jan Kowalski">
            <div id="err-imie" class="hidden text-red-500 text-xs font-bold mt-1 ml-1">Imię musi mieć minimum 3 znaki.</div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative">
            <div>
              <label for="email" class="block text-sm font-bold text-gray-700 mb-1">Adres e-mail</label>
              <input type="email" id="email" name="email" 
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-airtur-blue focus:ring-4 focus:ring-airtur-blue/20 outline-none transition bg-white" 
                placeholder="jan@przyklad.pl">
              <p class="text-[10px] text-gray-400 mt-1 uppercase font-bold tracking-tighter">Wygodna opcja dla zapytań ofertowych</p>
              <div id="err-email" class="hidden text-red-500 text-xs font-bold mt-1 ml-1">Proszę podać poprawny adres e-mail.</div>
            </div>
            
            <div>
              <label for="phone" class="block text-sm font-bold text-gray-700 mb-1">Numer telefonu</label>
              <input type="tel" id="phone" name="telefon" 
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-airtur-blue focus:ring-4 focus:ring-airtur-blue/20 outline-none transition bg-white" 
                placeholder="+48 000 000 000">
              <p class="text-[10px] text-gray-400 mt-1 uppercase font-bold tracking-tighter">Dla szybkiego kontaktu telefonicznego</p>
              <div id="err-telefon" class="hidden text-red-500 text-xs font-bold mt-1 ml-1">Numer telefonu musi mieć minimum 9 cyfr.</div>
            </div>

            <div id="contact-error" class="hidden absolute -bottom-5 left-0 text-red-500 text-[10px] font-bold italic">
                Proszę podać przynajmniej jedną, poprawną formę kontaktu.
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-bold text-gray-700 mb-1">Treść wiadomości (Opcjonalne)</label>
            <textarea id="message" name="wiadomosc" rows="5" 
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-airtur-blue focus:ring-4 focus:ring-airtur-blue/20 outline-none transition bg-white" 
              placeholder="Dzień dobry, interesuje mnie [montaż / serwis] w miejscowości…&#10;Mój przybliżony metraż to..."></textarea>
          </div>

          <div class="flex flex-col pt-2">
            <div class="flex items-start">
                <div class="flex items-center h-5">
                <input id="consent" name="zgoda" type="checkbox" required class="w-5 h-5 text-airtur-blue border-gray-300 rounded focus:ring-airtur-blue cursor-pointer">
                </div>
                <div class="ml-3 text-sm">
                <label for="consent" class="text-gray-600 cursor-pointer">
                    Akceptuję <a href="/regulamin" class="text-airtur-blue hover:underline font-semibold">Regulamin</a> oraz wyrażam zgodę na przetwarzanie moich danych zgodnie z <a href="/polityka-prywatnosci" class="text-airtur-blue hover:underline font-semibold">Polityką Prywatności</a>.
                </label>
                </div>
            </div>
            <div id="err-zgoda" class="hidden text-red-500 text-xs font-bold mt-2 pl-1">Akceptacja Regulaminu oraz Polityki Prywatności jest wymagana.</div>
          </div>

          <div class="pt-4">
            <button type="submit" id="submit-btn" class="submit-btn w-full bg-airtur-blue text-white font-black py-4 rounded-xl hover:bg-airtur-navy transition-all shadow-lg uppercase tracking-widest flex items-center justify-center gap-3 transform hover:-translate-y-0.5 cursor-pointer disabled:opacity-50">
              <span class="btn-text">WYŚLIJ WIADOMOŚĆ</span>
              <svg class="spinner hidden w-5 h-5 animate-spin text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            </button>
            <p class="text-xs text-gray-400 text-center mt-4 italic font-medium">
              * Imię i Nazwisko oraz przynajmniej jedna forma kontaktu są wymagane.
            </p>
          </div>
        </form>
      </div>

      <div class="lg:col-span-2 flex flex-col">
        <div class="bg-airtur-dark p-8 md:p-10 text-white">
          <h2 class="text-2xl md:text-3xl font-black mb-4 tracking-tight">Zadzwoń już teraz</h2>
          <p class="text-gray-300 mb-8 text-sm md:text-base">Wolisz kontakt bezpośredni? Zadzwoń do nas lub napisz e-mail.</p>
          
          <div class="space-y-6">
            <a href={companyConfig.contact.phoneLink} class="flex items-center gap-4 group">
              <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center group-hover:bg-airtur-blue transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase font-black tracking-widest mb-0.5">Telefon</p>
                <p class="text-xl font-black text-white group-hover:text-airtur-blue transition-colors">{companyConfig.contact.phoneFull}</p>
              </div>
            </a>

            <a href={companyConfig.contact.emailLink} class="flex items-center gap-4 group">
              <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center group-hover:bg-airtur-blue transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25 2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-400 uppercase font-black tracking-widest mb-0.5">E-mail</p>
                <p class="text-xl font-black text-white group-hover:text-airtur-blue transition-colors">{companyConfig.contact.email}</p>
              </div>
            </a>
          </div>
        </div>

        <div class="bg-white p-8 md:p-10 flex-grow flex flex-col justify-between border-t lg:border-t-0 lg:border-l border-gray-100">
          <div class="space-y-8">
            <div>
              <h3 class="text-xl font-black text-airtur-dark mb-4 tracking-tight">Dane Firmy:</h3>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-airtur-blue">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                  </svg>
                </div>
                <div class="text-gray-600 text-sm leading-relaxed">
                  <p class="font-black text-airtur-dark text-base">{companyConfig.name}</p>
                  <p>{companyConfig.address.street}</p>
                  <p>{companyConfig.address.postCode} {companyConfig.address.city}</p>
                </div>
              </div>
            </div>

            <div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-airtur-blue">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                </div>
                <div>
                  <p class="font-black text-airtur-dark mb-1 text-base tracking-tight">Godziny otwarcia biura:</p>
                  <div class="text-gray-600 text-sm space-y-1">
                    <p><span class="font-bold text-airtur-dark">Pn – Pt:</span> {companyConfig.workingHours.weekdays}</p>
                    <p><span class="font-bold text-airtur-dark">Sobota:</span> {companyConfig.workingHours.saturday}</p>
                    <p><span class="font-bold text-red-500">Niedziela:</span> {companyConfig.workingHours.sunday}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-10 pt-6 border-t border-gray-100">
            <p class="font-black text-airtur-dark mb-2 tracking-tight">{companyConfig.fullName}</p>
            <div class="flex flex-col gap-1 text-xs text-gray-400 font-bold uppercase tracking-widest">
              <p>NIP: {companyConfig.nip}</p>
              <p>REGON: {companyConfig.regon}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  /**
   * AirTUR Main Form v4.0 - Senior Refactor
   * Gwarancja 100% wyglądu + formatowanie telefonu + blokada spamu
   */
  const initMainContactForm = () => {
    const form = document.getElementById('main-contact-form');
    if (!form) return;

    const submitBtn = document.getElementById('submit-btn');
    const phoneInput = document.getElementById('phone');
    const errors = {
      imie: document.getElementById('err-imie'),
      email: document.getElementById('err-email'),
      telefon: document.getElementById('err-telefon'),
      zgoda: document.getElementById('err-zgoda'),
      general: document.getElementById('contact-error')
    };

    // --- 1. Formatuje telefon "w locie" (np. 123 456 789) ---
    phoneInput?.addEventListener('input', (e) => {
      let x = e.target.value.replace(/\D/g, '').match(/(\d{0,3})(\d{0,3})(\d{0,4})/);
      e.target.value = !x[2] ? x[1] : `${x[1]} ${x[2]}${x[3] ? ' ' + x[3] : ''}`;
    });

    // --- 2. Logika walidacji i wysyłki ---
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      let hasError = false;

      // [ANTISPAM] Honeypot - Silent Fail
      if (data.b_website) {
        window.location.assign('/podziekowanie/?cel=kontakt');
        return;
      }

      // [ANTISPAM] Rate Limiting (30 sek)
      const lastSent = localStorage.getItem('last_main_sent');
      if (lastSent && Date.now() - parseInt(lastSent) < 30000) {
        alert("Wiadomość została już wysłana. Prosimy o chwilę odstępu.");
        return;
      }

      // Reset wizualny błędów
      Object.values(errors).forEach(el => el?.classList.add('hidden'));
      form.querySelectorAll('input, textarea').forEach(el => el.classList.remove('border-red-400', 'bg-red-50'));

      // --- Walidacja Senior ---
      // Imię
      if (data.imie.trim().length < 3) {
        hasError = true;
        errors.imie.classList.remove('hidden');
        form.querySelector('[name="imie"]').classList.add('border-red-400', 'bg-red-50');
      }

      // Logika: Email lub Telefon
      const emailVal = data.email.trim();
      const phoneVal = data.telefon.replace(/\D/g, "");

      if (!emailVal && !phoneVal) {
        hasError = true;
        errors.general.classList.remove('hidden');
      }

      if (emailVal && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
        hasError = true;
        errors.email.classList.remove('hidden');
        form.querySelector('[name="email"]').classList.add('border-red-400', 'bg-red-50');
      }

      if (phoneVal && phoneVal.length < 9) {
        hasError = true;
        errors.telefon.classList.remove('hidden');
        form.querySelector('[name="telefon"]').classList.add('border-red-400', 'bg-red-50');
      }

      if (!data.zgoda) {
        hasError = true;
        errors.zgoda.classList.remove('hidden');
      }

      if (hasError) return;

      // --- Start Wysyłki ---
      const btnText = submitBtn.querySelector('.btn-text');
      const spinner = submitBtn.querySelector('.spinner');
      
      submitBtn.disabled = true;
      btnText.innerText = "WYSYŁANIE...";
      spinner.classList.remove('hidden');

      try {
        const res = await fetch('/api/send-form', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (res.ok) {
          localStorage.setItem('last_main_sent', Date.now().toString());
          window.location.assign('/podziekowanie/?cel=kontakt');
        } else throw new Error();
      } catch {
        alert("Problem z wysyłką. Zadzwoń bezpośrednio do nas!");
        submitBtn.disabled = false;
        btnText.innerText = "WYŚLIJ WIADOMOŚĆ";
        spinner.classList.add('hidden');
      }
    });

    // Czyścimy błędy przy pisaniu
    form.querySelectorAll('input, textarea').forEach(inp => {
      inp.addEventListener('input', () => {
        inp.classList.remove('border-red-400', 'bg-red-50');
        const name = inp.name;
        if(errors[name]) errors[name].classList.add('hidden');
        errors.general.classList.add('hidden');
        if(name === 'zgoda') errors.zgoda.classList.add('hidden');
      });
    });
  };

  initMainContactForm();
  document.addEventListener('astro:page-load', initMainContactForm);
</script>