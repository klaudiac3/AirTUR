<section id="nasze-wartosci" class="relative bg-white py-12 md:py-16 overflow-hidden">
  <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-full max-h-[500px] bg-airtur-blue/5 md:bg-airtur-blue/10 pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {values.map((item) => (
        <article class="group bg-white p-8 md:p-10 rounded-3xl shadow-lg border border-airtur-blue/5 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl flex flex-col items-center md:items-start text-center md:text-left">
          <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mb-6 text-airtur-blue shadow-sm border border-gray-50 transition-transform duration-500 group-hover:scale-110" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width={item.strokeWidth} stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.iconPath} />
            </svg>
          </div>
          <h3 class="text-xl md:text-2xl font-black text-airtur-dark mb-4 tracking-tight">{item.title}</h3>
          <p class="text-gray-500 leading-relaxed text-base font-medium">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>