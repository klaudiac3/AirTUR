---
// src/components/MobileStickyBar.astro
import { companyConfig } from '../data/companyConfig';
---

<div class="fixed bottom-0 left-0 w-full z-50 md:hidden flex bg-white shadow-[0_-4px_12px_rgba(0,0,0,0.1)] font-sans pb-[env(safe-area-inset-bottom)] border-t border-gray-100">
  
  <a 
    href={companyConfig.contact.phoneLink} 
    class="flex-1 flex items-center justify-center gap-2 py-4 text-airtur-dark font-bold text-[11px] sm:text-xs uppercase tracking-widest border-r border-gray-100 active:bg-gray-50 transition-colors"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-4 text-airtur-blue">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
    </svg>
    Zadzwoń
  </a>

  <a 
    href="/kontakt" 
    class="flex-1 bg-airtur-blue text-white flex items-center justify-center gap-2 py-4 font-bold text-[11px] sm:text-xs uppercase tracking-widest active:bg-airtur-navy transition-colors shadow-inner"
  >
    <svg xmlns="http://www.w3.org/2000/astro" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
    </svg>
    Bezpłatna wycena
  </a>

</div>

<style>
  /* [SEO/UX]: Zapobieganie miganiu przy ładowaniu */
  div {
    will-change: transform;
  }
</style>