---
import { getCollection } from 'astro:content';

const allCases = await getCollection('cases');
const sortedCases = allCases.sort((a, b) => (Number(a.data.caseId) || 0) - (Number(b.data.caseId) || 0));

// [ZASADA]: Potrójny bufor dla nieskończonej pętli
const loopedCases = [...sortedCases, ...sortedCases, ...sortedCases];
---

<section id="lista-przypadkow" class="bg-white pt-0 pb-16 md:pb-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative group/main">
    
    <button 
      id="slide-left" 
      aria-label="Poprzedni przypadek" 
      class="absolute left-2 lg:left-0 top-1/2 -translate-y-1/2 z-30 
             bg-white/95 backdrop-blur-sm p-4 rounded-full shadow-2xl text-airtur-blue 
             hover:bg-airtur-navy hover:text-white transition-all duration-300
             opacity-100 md:opacity-0 md:group-hover/main:opacity-100 flex items-center justify-center border border-gray-100 select-none active:scale-90"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
      </svg>
    </button>

    <button 
      id="slide-right" 
      aria-label="Następny przypadek" 
      class="absolute right-2 lg:right-0 top-1/2 -translate-y-1/2 z-30 
             bg-white/95 backdrop-blur-sm p-4 rounded-full shadow-2xl text-airtur-blue 
             hover:bg-airtur-navy hover:text-white transition-all duration-300
             opacity-100 md:opacity-0 md:group-hover/main:opacity-100 flex items-center justify-center border border-gray-100 select-none active:scale-90"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
      </svg>
    </button>

    <div id="carousel-window" class="overflow-hidden -mx-4 px-4 md:mx-0 md:px-0 cursor-grab active:cursor-grabbing">
      <div 
        id="cases-track"
        class="flex gap-6 md:gap-8 items-stretch" 
        style="will-change: transform;"
      >
        {loopedCases.map((item) => (
          <article class="shrink-0 w-[85vw] md:w-[45%] lg:w-[32%] flex flex-col h-auto">
            
            <a 
              href={`/studia-przypadkow/${item.slug}`} 
              class="group/card flex flex-col h-full bg-white border border-gray-100 rounded-3xl overflow-hidden hover:border-airtur-blue hover:shadow-2xl transition-all duration-500 relative"
              draggable="false"
            >
              
              <div class="relative h-52 md:h-60 overflow-hidden flex-shrink-0 bg-gray-50">
                <img 
                  src={item.data.image} 
                  alt={item.data.title} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover/card:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-airtur-dark/60 via-transparent to-transparent opacity-90"></div>
                
                <div class="absolute bottom-4 left-4">
                  <span class="bg-airtur-blue text-white text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest shadow-lg">
                    {item.data.location}
                  </span>
                </div>
              </div>

              <div class="p-6 md:p-8 flex flex-col flex-grow">
                
                <h3 class="text-xl md:text-2xl font-black text-airtur-dark mb-6 group-hover/card:text-airtur-blue transition-colors leading-[1.2] tracking-tight">
                  {item.data.tile_data.title_tile || item.data.title}
                </h3>

                <div class="space-y-5 mb-8 flex-grow">
                  <div class="pl-4 border-l-2 border-gray-100 group-hover/card:border-red-400/50 transition-colors">
                    <p class="text-[10px] text-gray-400 uppercase font-black tracking-widest mb-1">Problem</p>
                    <p class="text-sm text-gray-600 leading-snug">{item.data.tile_data.problem_short}</p>
                  </div>

                  <div class="pl-4 border-l-2 border-gray-100 group-hover/card:border-airtur-blue/50 transition-colors">
                    <p class="text-[10px] text-gray-400 uppercase font-black tracking-widest mb-1">Rozwiązanie</p>
                    <p class="text-sm text-gray-600 leading-snug">{item.data.tile_data.solution_short}</p>
                  </div>

                  <div class="pl-4 border-l-4 border-emerald-500 bg-emerald-50/50 py-2 rounded-r-xl">
                    <p class="text-[10px] text-emerald-600 uppercase font-black tracking-widest mb-1">Mierzalny Efekt</p>
                    <p class="text-sm md:text-base text-airtur-dark font-black tracking-tight">{item.data.tile_data.result_short}</p>
                  </div>
                </div>

                <div class="mt-auto pt-4">
                  <div class="w-full py-4 bg-white border-2 border-airtur-blue/20 text-airtur-blue rounded-xl font-black text-xs tracking-widest text-center 
                              group-hover/card:bg-airtur-blue group-hover/card:text-white group-hover/card:border-airtur-blue 
                              hover:!bg-airtur-navy hover:!border-airtur-navy
                              transition-all duration-300 flex items-center justify-center gap-3 uppercase">
                    Zobacz pełną analizę
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                      <path fill-rule="evenodd" d="M14.615 1.595a.75.75 0 0 1 .359.852L12.982 9.75h7.268a.75.75 0 0 1 .548 1.262l-10.5 11.25a.75.75 0 0 1-1.272-.71l1.992-7.302H3.75a.75.75 0 0 1-.548-1.262l10.5-11.25a.75.75 0 0 1 .913-.143Z" clip-rule="evenodd" />
                    </svg>
                  </div>
                </div>

              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const initSlider = () => {
    const track = document.getElementById("cases-track");
    const leftBtn = document.getElementById('slide-left');
    const rightBtn = document.getElementById('slide-right');
    const container = document.querySelector('.group\\/main');
    
    if (!track || !container) return;

    const items = Array.from(track.children);
    const count = items.length / 3;
    let currentIndex = count;
    let autoplayInterval;
    
    const getWidth = () => items[0].offsetWidth + parseInt(window.getComputedStyle(track).gap);

    const setPosition = (smooth = true) => {
      track.style.transition = smooth ? "transform 0.6s cubic-bezier(0.23, 1, 0.32, 1)" : "none";
      track.style.transform = `translateX(-${currentIndex * getWidth()}px)`;
    };

    const handleNext = () => { currentIndex++; setPosition(); };
    const handlePrev = () => { currentIndex--; setPosition(); };

    const startAutoplay = () => { autoplayInterval = setInterval(handleNext, 5000); };
    const stopAutoplay = () => { if (autoplayInterval) clearInterval(autoplayInterval); };

    container.addEventListener('mouseenter', stopAutoplay);
    container.addEventListener('mouseleave', startAutoplay);

    track.addEventListener('transitionend', () => {
      if (currentIndex >= count * 2) { currentIndex = count; setPosition(false); }
      if (currentIndex < count) { currentIndex = count * 2 - 1; setPosition(false); }
    });

    // Swipe Support
    let startX = 0, isDragging = false;
    track.addEventListener('touchstart', (e) => { 
      stopAutoplay();
      startX = e.touches[0].clientX; 
      isDragging = true; 
      track.style.transition = 'none'; 
    });
    
    track.addEventListener('touchmove', (e) => { 
      if (!isDragging) return;
      const x = e.touches[0].clientX;
      const walk = (x - startX);
      track.style.transform = `translateX(${-currentIndex * getWidth() + walk}px)`;
    });
    
    track.addEventListener('touchend', (e) => {
      isDragging = false;
      const walk = e.changedTouches[0].clientX - startX;
      if (Math.abs(walk) > 100) walk > 0 ? handlePrev() : handleNext();
      else setPosition();
      startAutoplay();
    });

    leftBtn?.addEventListener('click', () => { handlePrev(); stopAutoplay(); });
    rightBtn?.addEventListener('click', () => { handleNext(); stopAutoplay(); });
    
    window.addEventListener('resize', () => setPosition(false));
    setTimeout(() => { setPosition(false); startAutoplay(); }, 10);
  };

  document.addEventListener('astro:page-load', initSlider);
  initSlider();
</script>