---
const navItems = [
  { id: 'montaz', label: 'Montaż', labelDesktop: 'Precyzyjny Montaż' },
  { id: 'serwis', label: 'Serwis', labelDesktop: 'Serwis' },
  { id: 'analiza', label: 'Analiza', labelDesktop: 'Analiza i Doradztwo' },
];
---

<nav 
  id="offer-side-nav" 
  class="hidden lg:flex fixed right-8 top-1/2 -translate-y-1/2 z-50 flex-col items-end gap-8 transition-opacity duration-500 opacity-0 pointer-events-none"
>
  <div class="relative flex flex-col items-end py-4">
    <div class="absolute right-[5px] top-0 bottom-0 w-[2px] bg-gray-100 rounded-full"></div>
    
    <div 
      id="progress-bar-fill" 
      class="absolute right-[5px] top-0 w-[2px] bg-airtur-blue rounded-full transition-all duration-100 ease-out"
      style="height: 0%; box-shadow: 0 0 10px var(--color-airtur-blue);"
    ></div>

    <div class="flex flex-col justify-between h-[300px] w-full">
      {navItems.map((item) => (
        <a 
          href={`#${item.id}`} 
          class="nav-dot-container group flex items-center justify-end gap-4 relative cursor-pointer"
          data-target={item.id}
        >
          <span class="nav-label text-[10px] uppercase tracking-[0.2em] transition-colors duration-300">
            {item.labelDesktop}
          </span>
          <div class="relative">
            <div class="dot-indicator w-3 h-3 rounded-full border-2 border-gray-200 bg-white group-hover:border-airtur-blue transition-all duration-300 z-10 relative"></div>
            <div class="dot-glow absolute inset-0 bg-airtur-blue rounded-full opacity-0 transition-opacity duration-300 blur-sm"></div>
          </div>
        </a>
      ))}
    </div>
  </div>
</nav>

<nav 
  id="offer-mobile-nav" 
  class="lg:hidden fixed top-24 left-0 w-full bg-white/95 backdrop-blur-sm shadow-md border-b border-gray-100 z-40 transition-transform duration-500 -translate-y-[200%]"
>
  <div class="flex justify-around items-center h-12 max-w-7xl mx-auto px-2">
    {navItems.map((item) => (
      <a 
        href={`#${item.id}`}
        class="mobile-nav-item text-[10px] font-bold uppercase tracking-wide text-gray-400 py-2 px-2 transition-colors duration-300 border-b-2 border-transparent"
        data-target={item.id}
      >
        {item.label}
      </a>
    ))}
  </div>
  <div class="absolute bottom-0 left-0 w-full h-[2px] bg-gray-100">
    <div 
      id="mobile-progress-bar-fill" 
      class="h-full bg-airtur-blue transition-all duration-100 ease-out"
      style="width: 0%; box-shadow: 0 0 8px var(--color-airtur-blue);"
    ></div>
  </div>
</nav>

<style>
  /** * [SENIOR FIX]: Używamy zmiennych var(--color-...) i natywnego CSS.
   * Dzięki temu terminal nie wywala błędu o nieznanych klasach Tailwind w @apply.
   */
  
  /* STYL DESKTOP */
  .nav-label {
    color: #D1D5DB; /* text-gray-300 */
    font-weight: 700;
  }

  .nav-dot-container.active .dot-indicator {
    background-color: var(--color-airtur-blue);
    border-color: var(--color-airtur-blue);
    transform: scale(1.3);
  }

  .nav-dot-container.active .dot-glow { 
    opacity: 0.6; 
  }

  .nav-dot-container.active .nav-label {
    color: var(--color-airtur-blue);
    font-weight: 900; /* Nasz "font-black" */
  }

  #offer-side-nav.visible { 
    opacity: 1; 
    pointer-events: auto; 
  }

  /* STYL MOBILE */
  .mobile-nav-item.active {
    color: var(--color-airtur-blue);
    font-weight: 900; 
  }
</style>

<script>
  // Przywrócona Twoja działająca logika z drobnymi poprawkami dla pewności
  const handleOfferNav = () => {
    const navDesktop = document.getElementById('offer-side-nav');
    const navMobile = document.getElementById('offer-mobile-nav');
    const progressDesktop = document.getElementById('progress-bar-fill');
    const progressMobile = document.getElementById('mobile-progress-bar-fill');
    
    const dotsDesktop = document.querySelectorAll('.nav-dot-container');
    const itemsMobile = document.querySelectorAll('.mobile-nav-item');

    // Pobieramy sekcje
    const sections = {
      montaz: document.getElementById('montaz'),
      serwis: document.getElementById('serwis'),
      analiza: document.getElementById('analiza')
    };

    if (!sections.montaz || !sections.serwis || !sections.analiza) return;

    const calculate = () => {
      const scrollY = window.scrollY;
      const viewportCenter = scrollY + (window.innerHeight / 2);

      const posMontaz = sections.montaz.offsetTop;
      const posSerwis = sections.serwis.offsetTop;
      const posAnaliza = sections.analiza.offsetTop;
      const posEnd = posAnaliza + sections.analiza.offsetHeight;

      // 1. Widoczność
      const shouldShow = viewportCenter > (posMontaz - 200) && viewportCenter < posEnd;

      if (shouldShow) {
        navDesktop?.classList.add('visible');
        if (navMobile) {
          navMobile.classList.remove('-translate-y-[200%]');
          navMobile.classList.add('translate-y-0');
        }
      } else {
        navDesktop?.classList.remove('visible');
        if (navMobile) {
          navMobile.classList.remove('translate-y-0');
          navMobile.classList.add('-translate-y-[200%]');
        }
      }

      // 2. Progres
      let progress = 0;
      if (viewportCenter >= posMontaz && viewportCenter < posSerwis) {
        progress = ((viewportCenter - posMontaz) / (posSerwis - posMontaz)) * 50;
      } else if (viewportCenter >= posSerwis && viewportCenter < posAnaliza) {
        progress = 50 + ((viewportCenter - posSerwis) / (posAnaliza - posSerwis)) * 50;
      } else if (viewportCenter >= posAnaliza) {
        progress = 100;
      }

      if (progressDesktop) progressDesktop.style.height = `${progress}%`;
      if (progressMobile) progressMobile.style.width = `${progress}%`;

      // 3. Aktywne stany
      [...dotsDesktop, ...itemsMobile].forEach(el => {
        // @ts-ignore
        const targetId = el.dataset.target;
        const targetSec = sections[targetId];
        if (targetSec) {
          const top = targetSec.offsetTop;
          const bottom = top + targetSec.offsetHeight;
          const effectiveTop = (targetId === 'montaz') ? top - 300 : top;

          if (viewportCenter >= effectiveTop && viewportCenter <= bottom) {
            el.classList.add('active');
          } else {
            el.classList.remove('active');
          }
        }
      });
    };

    window.addEventListener('scroll', calculate, { passive: true });
    calculate();
  };

  // Astro page-load dla wsparcia nawigacji między stronami
  document.addEventListener('astro:page-load', handleOfferNav);
  // Fallback
  document.addEventListener('DOMContentLoaded', handleOfferNav);
</script>