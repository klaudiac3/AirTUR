---
/**
 * [SENIOR NOTE]: Pasek autorytetu (Social Proof).
 * Wykorzystujemy infinite marquee dla dynamiki sekcji.
 * Logotypy w skali szarości, aby nie odciągać uwagi od merytoryki oferty.
 */

const partners = [
  "GREE", "AUXlogo", "DAIKIN", "SAMSUNG", "PANASONIC", "KAISAI", 
  "SEVRA", "TOSHIBA", "MITSUBISHI", "HAIER", "LG", "COOPER&HUNTER", 
  "ROTENSO", "MDV", "FUJITSU", "FUJI_ELECTRIC" 
];

// Duplikujemy dla płynności pętli
const loopedPartners = [...partners, ...partners, ...partners];
---

<section class="bg-airtur-gray py-10 md:py-14 border-y border-gray-100 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-10 text-center">
    
    <h2 class="text-2xl md:text-3xl font-black text-airtur-dark mb-4 tracking-tight leading-tight">
      Partnerzy Technologiczni: Gwarancja Niezawodności</span>
    </h2>
    
    <p class="text-sm md:text-base text-gray-500 max-w-2xl mx-auto leading-relaxed font-medium text-pretty">
      Instalujemy wyłącznie systemy liderów rynku HVAC. Każde urządzenie dobieramy pod kątem maksymalnej wydajności grzewczej i najwyższego współczynnika ROI.
    </p>

  </div>

  <div class="relative w-full">
    <div class="absolute top-0 left-0 h-full w-20 md:w-40 bg-gradient-to-r from-airtur-gray to-transparent z-10 pointer-events-none"></div>
    <div class="absolute top-0 right-0 h-full w-20 md:w-40 bg-gradient-to-l from-airtur-gray to-transparent z-10 pointer-events-none"></div>

    <div class="logo-slider">
      <div class="logo-track flex items-center gap-16 md:gap-24">
        {loopedPartners.map((logo, index) => (
          <div 
            class="flex-shrink-0 flex items-center justify-center h-12 w-28 md:w-36 grayscale opacity-40 hover:grayscale-0 hover:opacity-100 transition-all duration-500 hover:scale-110 cursor-default"
            aria-hidden={index >= partners.length ? "true" : "false"}
          >
            <img 
              src={`/logo/${logo}.jpg`} 
              alt={`Autoryzowany partner ${logo}`} 
              class="max-h-full max-w-full object-contain mix-blend-multiply" 
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /**
   * [UX]: Animacja Marquee. 
   * Przesuwamy o -33.33% ponieważ mamy 3 kopie listy partnerów.
   */
  .logo-slider {
    width: 100%;
    overflow: hidden;
    display: flex;
  }

  .logo-track {
    display: flex;
    animation: marquee 50s linear infinite;
    width: max-content;
    will-change: transform; /* Optymalizacja pod GPU (płynność) */
  }

  /* Pauza na hoverze dla wygody użytkownika */
  .logo-track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.3333%); }
  }

  /* Responsywna szybkość (wolniej na mobile dla czytelności) */
  @media (max-width: 768px) {
    .logo-track {
      animation-duration: 35s;
    }
  }
</style>