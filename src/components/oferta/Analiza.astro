---
/** * [DATA]: Tutaj zarządzasz listą korzyści. 
 * Możesz dopisać nowy wiersz lub usunąć istniejący, a grid sam się dostosuje.
 */
const consultationPerks = [
  "Indywidualny dobór mocy urządzenia – dopasujemy parametry systemu do kubatury Twoich pomieszczeń oraz specyfiki budynku, aby zapewnić wydajność bez przepłacania za zbyt duże jednostki.",
  "Analizę funkcjonalności systemów – wskażemy różnice w technologiach (np. jakość filtracji powietrza, poziom hałasu czy sterowanie Wi-Fi), które realnie wpływają na Twój codzienny komfort.",
  "Prognozę kosztów użytkowania – zamiast sztywnych wyliczeń, przedstawimy Ci orientacyjny pobór energii dla wybranych modeli, co ułatwi zaplanowanie domowych wydatków.",
  "Zestawienie 3 wariantów instalacji – otrzymasz przejrzyste porównanie opcji: ekonomicznej, optymalnej oraz premium, co pozwoli Ci wybrać rozwiązanie najlepiej trafiające w Twój budżet i oczekiwania."
];
---

<section id="analiza" class="pt-2 pb-12 md:pt-4 md:pb-24 bg-white scroll-mt-24">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-10 md:mb-14">
    

      <h2 class="text-3xl md:text-5xl font-black text-airtur-dark mb-6 tracking-tight leading-[1.1] text-balance max-w-4xl mx-auto">
        Analiza Techniczna i <span class="text-airtur-blue">Doradztwo Inwestycyjne</span>
      </h2>
      
      <p class="text-base md:text-lg text-gray-500 leading-relaxed max-w-3xl mx-auto font-medium text-pretty">
        Każdy dom jest inny, dlatego zanim wybierzemy model klimatyzatora, musimy poznać Twój budynek. Podczas bezpłatnej konsultacji sprawdzamy warunki techniczne oraz Twoje oczekiwania. Dzięki temu dobieramy urządzenie o odpowiedniej mocy – takie, które nie będzie za słabe, ale też nie narazi Cię na zbędne koszty wynikające z przewymiarowania sprzętu. Podpowiadamy, które rozwiązania faktycznie się sprawdzą, a z których warto zrezygnować, by nie przepłacać.
      </p>
    </div>

    <div class="bg-airtur-dark rounded-[2.5rem] p-8 md:p-16 text-white shadow-2xl relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-airtur-blue/10 rounded-full blur-[100px] -mr-32 -mt-32 pointer-events-none"></div>
      
      <div class="relative z-10">
        <h3 class="text-xl md:text-2xl font-black text-center mb-10 md:mb-14 tracking-tight">
          Co otrzymasz podczas darmowej konsultacji?
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-y-6 md:gap-y-10 gap-x-12 mb-12 md:mb-16">
          
          {consultationPerks.map((perk) => (
            <div class="flex items-start gap-4 group">
              <div class="shrink-0 w-6 h-6 rounded-full bg-airtur-blue flex items-center justify-center mt-0.5 shadow-[0_0_15px_rgba(10,179,198,0.4)] transition-transform duration-300 group-hover:scale-110">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="4" stroke="currentColor" class="w-3.5 h-3.5 text-white">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              </div>
              <p class="text-sm md:text-base text-gray-300 font-medium leading-relaxed group-hover:text-white transition-colors duration-300">
                {perk}
              </p>
            </div>
          ))}

        </div>

        <div class="text-center border-t border-white/10 pt-10 md:pt-14">
          <h4 class="text-lg md:text-xl font-black text-white mb-8 tracking-tight italic">
            Zacznij od najważniejszego kroku.
          </h4>
          
          <a href="/kontakt" class="inline-flex items-center justify-center w-full sm:w-auto bg-airtur-blue text-white px-10 py-5 rounded-2xl font-black text-sm md:text-base tracking-[0.2em] shadow-xl shadow-airtur-blue/20 hover:bg-airtur-navy hover:-translate-y-1.5 transition-all duration-300 uppercase group">
              <span>UMÓW SIĘ NA BEZPŁATNĄ ANALIZĘ</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 ml-3 group-hover:translate-x-1.5 transition-transform">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
          </a>
          
          <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest mt-10 opacity-50">
            * Konsultacja jest bezpłatna i nie zobowiązuje do zakupu.
          </p>
        </div>
      </div>
    </div>

  </div>
</section>