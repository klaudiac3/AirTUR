---
import { companyConfig } from '../../data/companyConfig';

/** * [DATA]: Benefity Serwisu
 */
const benefits = [
  {
    title: "Maksymalna wydajność",
    desc: "Optymalizacja pracy systemu, obniżająca koszty eksploatacji.",
    icon: "M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z",
    rotate: "rotate-2"
  },
  {
    title: "Czystość i Zdrowie",
    desc: "Eliminacja drobnoustrojów i alergenów z filtrów.",
    icon: "M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 0121 12z",
    rotate: "-rotate-2"
  },
  {
    title: "Niezawodność",
    desc: "Proaktywne unikanie niespodziewanych awarii.",
    icon: "M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.702.127 1.597 1.097 1.896 1.966 1.896 1.966M8.685 2.25l-1.904 1.904m4.034-3.834l-1.132 2.768m4.935-2.203L12.55 4.509",
    rotate: "rotate-3"
  },
  {
    title: "Dłuższa żywotność",
    desc: "Zwiększenie trwałości i sprawności całego systemu.",
    icon: "M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0z",
    rotate: "-rotate-1"
  }
];
---

<section id="serwis" class="pt-2 md:pt-4 pb-12 md:pb-20 bg-white scroll-mt-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="relative py-12 md:py-16 mb-20 mt-0">
      <div class="absolute inset-0 bg-airtur-blue/5 rounded-[3.5rem] -mx-4 md:-mx-12 pointer-events-none border border-airtur-blue/5"></div>

      <div class="relative z-10">
        <div class="text-center mb-12">
          <h2 class="text-2xl md:text-4xl font-black text-airtur-dark tracking-tight leading-[1.1] mb-6 text-balance max-w-4xl mx-auto">
            Opieka Techniczna i Serwis: <span class="text-airtur-blue">Żeby system działał tak, jak pierwszego dnia</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
          <div class="lg:col-span-5 space-y-6">
            <p class="text-base md:text-lg text-gray-600 leading-relaxed font-medium">
              Zakup nowoczesnego systemu HVAC to mądra decyzja finansowa. <strong class="text-airtur-dark font-black">Regularny serwis</strong> to fundament, by ta decyzja przynosiła maksymalne korzyści przez wiele lat.
            </p>
            <p class="text-sm md:text-base text-gray-500 leading-relaxed">
              Nasz zespół zadba o to, by Twój system pracował z najwyższą wydajnością, zapewniając niskie koszty eksploatacji i czyste, zdrowe powietrze dla Twojej rodziny. Możesz to postrzegać jako dodatkowy wydatek albo jako utrzymanie pełnej kontroli nad Twoją inwestycją.
            </p>
          </div>

          <div class="lg:col-span-7">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {benefits.map(item => (
                <div class="bg-white p-6 rounded-3xl shadow-lg border border-airtur-blue/5 flex gap-4 transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
                  <div class={`shrink-0 w-12 h-12 rounded-2xl bg-airtur-blue/5 flex items-center justify-center text-airtur-blue ${item.rotate} transition-transform group-hover:scale-110`}>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                      <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-black text-airtur-dark text-base tracking-tight mb-1">{item.title}</h4>
                    <p class="text-[11px] text-gray-400 leading-relaxed font-medium">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h3 class="text-2xl md:text-3xl font-black text-airtur-dark tracking-tight mb-4">
          Chcesz umówić się na serwis lub <span class="text-airtur-blue">Masz pytania?</span>
        </h3>
        <p class="text-gray-500 font-medium uppercase text-[10px] tracking-[0.2em]">Wybierz preferowaną formę kontaktu:</p>
      </div>

      <div class="flex p-1.5 bg-gray-100 rounded-2xl mb-10 max-w-md mx-auto">
        <button id="tab-email-serwis" class="flex-1 px-6 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest transition-all duration-300 bg-airtur-dark text-white shadow-lg cursor-pointer">
          E-mail
        </button>
        <button id="tab-phone-serwis" class="flex-1 px-6 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest transition-all duration-300 text-gray-500 hover:text-airtur-dark cursor-pointer">
          Telefon
        </button>
      </div>

      <div class="bg-white p-8 md:p-12 rounded-[2.5rem] shadow-2xl border border-gray-100">
        
        <div id="form-email-serwis" class="transition-all duration-500">
          <form id="serwis-form-mail" name="zgloszenie-serwis-mail" class="space-y-6" novalidate>
            <div class="hidden" aria-hidden="true"><input type="text" name="b_website" tabindex="-1" value="" /></div>
            <input type="hidden" name="form-name" value="zgloszenie-serwis-mail" />
            <input type="hidden" name="source" value="oferta_serwis_email" />
            <input type="hidden" name="cel" value="serwis" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="name-serwis-mail" class="block text-[10px] font-black text-airtur-dark uppercase tracking-widest ml-1">Imię i Nazwisko *</label>
                <input type="text" id="name-serwis-mail" name="imie" required 
                  class="w-full px-5 py-4 rounded-2xl border border-gray-200 bg-gray-50/50 outline-none transition-all duration-300 focus:bg-white focus:border-airtur-blue focus:ring-4 focus:ring-airtur-blue/5 text-airtur-dark font-medium" 
                  placeholder="Twoje dane">
                <div id="err-imie-serwis-mail" class="hidden text-[10px] font-black text-red-500 mt-2 ml-4 uppercase">Min. 3 znaki.</div>
              </div>
              <div class="space-y-2">
                <label for="email-serwis-field" class="block text-[10px] font-black text-airtur-dark uppercase tracking-widest ml-1">Adres E-mail *</label>
                <input type="email" id="email-serwis-field" name="email" required 
                  class="w-full px-5 py-4 rounded-2xl border border-gray-200 bg-gray-50/50 outline-none transition-all duration-300 focus:bg-white focus:border-airtur-blue focus:ring-4 focus:ring-airtur-blue/5 text-airtur-dark font-medium" 
                  placeholder="twoj@email.pl">
                <div id="err-email-serwis-mail" class="hidden text-[10px] font-black text-red-500 mt-2 ml-4 uppercase">Podaj poprawny e-mail.</div>
              </div>
            </div>
            
            <div class="space-y-2">
              <label for="message-serwis-mail" class="block text-[10px] font-black text-airtur-dark uppercase tracking-widest ml-1">Szczegóły zgłoszenia</label>
              <textarea id="message-serwis-mail" name="wiadomosc" rows="4" 
                class="w-full px-5 py-4 rounded-2xl border border-gray-200 bg-gray-50/50 outline-none transition-all duration-300 focus:bg-white focus:border-airtur-blue focus:ring-4 focus:ring-airtur-blue/5 text-airtur-dark font-medium resize-none text-sm leading-relaxed" 
                placeholder={"Model urządzenia / Typ usterki / Preferowany termin przeglądu"}></textarea>
            </div>

            <div class="space-y-2">
              <div class="flex items-start gap-3">
                <input type="checkbox" id="consent-serwis-mail" name="zgoda" required class="w-5 h-5 text-airtur-blue border-gray-200 rounded focus:ring-airtur-blue/20 cursor-pointer">
                <label for="consent-serwis-mail" class="text-[11px] text-gray-500 cursor-pointer leading-tight">
                  Akceptuję <a href="/regulamin" class="text-airtur-blue font-bold hover:underline">Regulamin</a> i wyrażam zgodę na przetwarzanie danych (<a href="/polityka-prywatnosci" class="text-airtur-blue font-bold hover:underline">Polityka Prywatności</a>).
                </label>
              </div>
              <div id="err-zgoda-serwis-mail" class="hidden text-[10px] font-black text-red-500 mt-2 ml-4 uppercase">Zgoda jest wymagana.</div>
            </div>

            <button type="submit" class="submit-btn group relative w-full py-5 bg-airtur-blue text-white rounded-2xl font-black text-[13px] tracking-[0.25em] shadow-xl hover:bg-airtur-navy transition-all duration-300 uppercase flex items-center justify-center">
              <span class="btn-text">Wyślij zgłoszenie</span>
              <svg class="spinner hidden w-5 h-5 ml-3 animate-spin text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            </button>
          </form>
        </div>

        <div id="form-phone-serwis" class="hidden transition-all duration-500">
          <form id="serwis-form-phone" name="zgloszenie-serwis-phone" class="space-y-6" novalidate>
            <div class="hidden" aria-hidden="true"><input type="text" name="b_website" tabindex="-1" value="" /></div>
            <input type="hidden" name="form-name" value="zgloszenie-serwis-phone" />
            <input type="hidden" name="source" value="oferta_serwis_telefon" />
            <input type="hidden" name="cel" value="serwis" />
            
            <div class="bg-airtur-blue/5 p-5 rounded-2xl border border-airtur-blue/10 mb-8 text-center">
              <p class="text-airtur-dark font-black text-sm tracking-tight">Zostaw numer. Oddzwonimy ustalić termin serwisu.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="name-serwis-phone" class="block text-[10px] font-black text-airtur-dark uppercase tracking-widest ml-1">Imię *</label>
                <input type="text" id="name-serwis-phone" name="imie" required class="w-full px-5 py-4 rounded-2xl border border-gray-200 bg-gray-50/50 outline-none transition-all duration-300 focus:bg-white focus:border-airtur-blue focus:ring-4 focus:ring-airtur-blue/5 text-airtur-dark font-medium" placeholder="Wpisz imię">
                <div id="err-imie-serwis-phone" class="hidden text-[10px] font-black text-red-500 mt-2 ml-4 uppercase">Min. 3 znaki.</div>
              </div>
              <div class="space-y-2">
                <label for="phone-serwis-field" class="block text-[10px] font-black text-airtur-dark uppercase tracking-widest ml-1">Numer Telefonu *</label>
                <input type="tel" id="phone-serwis-field" name="telefon" required class="w-full px-5 py-4 rounded-2xl border border-gray-200 bg-gray-50/50 outline-none transition-all duration-300 focus:bg-white focus:border-airtur-blue focus:ring-4 focus:ring-airtur-blue/5 text-airtur-dark font-medium" placeholder="+48 ...">
                <div id="err-telefon-serwis-phone" class="hidden text-[10px] font-black text-red-500 mt-2 ml-4 uppercase">Podaj min. 9 cyfr.</div>
              </div>
            </div>

            <div class="space-y-2">
              <div class="flex items-start gap-3">
                <input type="checkbox" id="consent-serwis-phone" name="zgoda" required class="w-5 h-5 text-airtur-blue border-gray-200 rounded focus:ring-airtur-blue/20 cursor-pointer">
                <label for="consent-phone" class="text-[11px] text-gray-500 cursor-pointer">Wyrażam zgodę na kontakt telefoniczny. Akceptuję <a href="/regulamin" class="text-airtur-blue font-bold hover:underline">Regulamin</a> i wyrażam zgodę na przetwarzanie danych (<a href="/polityka-prywatnosci" class="text-airtur-blue font-bold hover:underline">Polityka Prywatności</a>).
              </div>
              <div id="err-zgoda-serwis-phone" class="hidden text-[10px] font-black text-red-500 mt-2 ml-4 uppercase">Zgoda jest wymagana.</div>
            </div>

            <button type="submit" class="submit-btn group relative w-full py-5 bg-airtur-dark text-white rounded-2xl font-black text-[13px] tracking-[0.25em] shadow-xl hover:bg-black transition-all duration-300 uppercase flex items-center justify-center">
              <span class="btn-text">Proszę o telefon</span>
              <svg class="spinner hidden w-5 h-5 ml-3 animate-spin text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>
</section>

<script is:inline>
  /** * Form Engine v5.1 - SERWIS 100% Sync with Montaż
   */
  const initSerwisForm = () => {
    const UI = {
      tabEmail: document.getElementById('tab-email-serwis'),
      tabPhone: document.getElementById('tab-phone-serwis'),
      formEmailCont: document.getElementById('form-email-serwis'),
      formPhoneCont: document.getElementById('form-phone-serwis'),
      phoneInput: document.getElementById('phone-serwis-field')
    };

    if (!UI.tabEmail || !UI.tabPhone) return;

    // 1. Phone Formatting "Live"
    UI.phoneInput?.addEventListener('input', (e) => {
      let x = e.target.value.replace(/\D/g, '').match(/(\d{0,3})(\d{0,3})(\d{0,4})/);
      e.target.value = !x[2] ? x[1] : `${x[1]} ${x[2]}${x[3] ? ' ' + x[3] : ''}`;
    });

    // 2. Tab Logic (Identyczna z Montażem)
    const setTab = (active, inactive, show, hide) => {
      active.classList.add('bg-airtur-dark', 'text-white', 'shadow-lg');
      active.classList.remove('text-gray-500');
      inactive.classList.remove('bg-airtur-dark', 'text-white', 'shadow-lg');
      inactive.classList.add('text-gray-500');
      show.classList.remove('hidden');
      hide.classList.add('hidden');
    };

    UI.tabEmail.addEventListener('click', () => setTab(UI.tabEmail, UI.tabPhone, UI.formEmailCont, UI.formPhoneCont));
    UI.tabPhone.addEventListener('click', () => setTab(UI.tabPhone, UI.tabEmail, UI.formPhoneCont, UI.formEmailCont));

    // 3. Validation & Submission
    const forms = document.querySelectorAll('#serwis-form-mail, #serwis-form-phone');
    
    forms.forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const targetForm = e.currentTarget;
        const formData = new FormData(targetForm);
        const data = Object.fromEntries(formData.entries());
        const suffix = targetForm.id === 'serwis-form-mail' ? 'serwis-mail' : 'serwis-phone';
        let hasError = false;

        if (data.b_website) {
          window.location.assign('/podziekowanie/?cel=serwis');
          return;
        }

        const lastSent = localStorage.getItem('last_serwis_sent');
        if (lastSent && Date.now() - parseInt(lastSent) < 20000) {
          alert("Poczekaj chwilę przed kolejną próbą.");
          return;
        }

        const resetErrors = () => {
          targetForm.querySelectorAll('.text-red-500').forEach(el => el.classList.add('hidden'));
          targetForm.querySelectorAll('input, textarea').forEach(el => el.classList.remove('border-red-500', 'bg-red-50'));
        };
        resetErrors();

        // Walidacja Imię
        if (data.imie.trim().length < 3) {
          hasError = true;
          document.getElementById(`err-imie-${suffix}`).classList.remove('hidden');
          targetForm.querySelector('[name="imie"]').classList.add('border-red-500', 'bg-red-50');
        }

        // Walidacja Email (tylko w mailowym)
        if (targetForm.id === 'serwis-form-mail' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) {
          hasError = true;
          document.getElementById(`err-email-${suffix}`).classList.remove('hidden');
          targetForm.querySelector('[name="email"]').classList.add('border-red-500', 'bg-red-50');
        }

        // Walidacja Telefon (tylko w tel)
        if (targetForm.id === 'serwis-form-phone' && data.telefon.replace(/\D/g, '').length < 9) {
          hasError = true;
          document.getElementById(`err-telefon-${suffix}`).classList.remove('hidden');
          targetForm.querySelector('[name="telefon"]').classList.add('border-red-500', 'bg-red-50');
        }

        if (!data.zgoda) {
          hasError = true;
          document.getElementById(`err-zgoda-${suffix}`).classList.remove('hidden');
        }

        if (hasError) return;

        const btn = targetForm.querySelector('.submit-btn');
        const btnText = btn.querySelector('.btn-text');
        const spinner = btn.querySelector('.spinner');
        btn.disabled = true;
        btnText.innerText = "WYSYŁANIE...";
        spinner.classList.remove('hidden');

        try {
          const res = await fetch('/api/send-form', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          if (res.ok) {
            localStorage.setItem('last_serwis_sent', Date.now().toString());
            window.location.assign('/podziekowanie/?cel=serwis');
          } else throw new Error();
        } catch (err) {
          btn.disabled = false;
          btnText.innerText = "SPRÓBUJ PONOWNIE";
          spinner.classList.add('hidden');
          alert("Błąd połączenia. Zadzwoń do nas!");
        }
      });

      // Live error clearing
      form.querySelectorAll('input, textarea').forEach(inp => {
        inp.addEventListener('input', () => {
          inp.classList.remove('border-red-500', 'bg-red-50');
          const name = inp.name === 'telefon' ? 'telefon' : (inp.name === 'email' ? 'email' : 'imie');
          const errEl = document.getElementById(`err-${name}-${suffix}`);
          if (errEl) errEl.classList.add('hidden');
          document.getElementById(`err-zgoda-${suffix}`)?.classList.add('hidden');
        });
      });
    });
  };

  initSerwisForm();
  document.addEventListener('astro:page-load', initSerwisForm);
</script>