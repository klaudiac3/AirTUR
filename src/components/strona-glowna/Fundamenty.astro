---
// [DATA]: Treść fundamentów (Zasada Single Responsibility)
const foundations = [
  {
    title: "Przejrzystość",
    description: "Zanim zaczniemy, otrzymasz od nas konkretną wycenę. Bez domysłów i bez ukrytych dopłat na koniec prac. Wiesz dokładnie, jaki budżet planujesz i co wchodzi w skład instalacji.",
    iconPath: "M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z",
    rotateClass: "group-hover:rotate-3"
  },
  {
    title: "Kultura Pracy",
    description: "Szanujemy Twoją przestrzeń tak, jak własną. Proces montażu projektujemy tak, aby miejsce pracy pozostało w należytym porządku – niezależnie od etapu.",
    iconPath: "M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z",
    rotateClass: "group-hover:-rotate-3"
  },
  {
    title: "Terminowość",
    description: "Umawiamy się na konkretne terminy i robimy wszystko, aby ich dotrzymać. Stawiamy na szczerą komunikację – jeśli pojawi się przeszkoda, dowiesz się pierwszy.",
    iconPath: "M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
    rotateClass: "group-hover:rotate-6"
  }
];
---

<section 
  id="fundamenty" 
  class="relative bg-white pt-12 md:pt-16 pb-20 md:pb-24 overflow-hidden" 
  aria-labelledby="foundations-title"
>
  <div class="absolute inset-x-0 top-44 md:top-48 bottom-0 bg-airtur-blue/5 md:bg-airtur-blue/10 pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-12 md:mb-16">
      <h2 id="foundations-title" class="text-3xl md:text-5xl font-black text-airtur-dark mb-4 tracking-tight leading-[1.1]">
        Fundamenty Standardu <span class="text-airtur-blue">AirTUR</span>
      </h2>
      <p class="text-base md:text-lg text-gray-500 max-w-2xl mx-auto text-pretty font-medium">
        Zasady, według których działamy każdego dnia.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {foundations.map((item) => (
        <article class="group bg-white p-8 md:p-10 rounded-[2.5rem] shadow-lg border border-airtur-blue/5 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl flex flex-col items-center md:items-start text-center md:text-left">
          
          <div class={`w-16 h-16 md:w-20 md:h-20 bg-white rounded-2xl flex items-center justify-center mb-8 text-airtur-blue shadow-sm border border-gray-50 transition-transform duration-500 ${item.rotateClass}`}>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 md:w-10 md:h-10">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.iconPath} />
            </svg>
          </div>

          <h3 class="text-xl md:text-2xl font-black text-airtur-dark mb-4 tracking-tight">
            {item.title}
          </h3>

          <p class="text-gray-500 leading-relaxed text-sm md:text-base font-medium">
            {item.description}
          </p>

        </article>
      ))}
    </div>
  </div>
</section>