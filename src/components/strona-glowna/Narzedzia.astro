---
import { Image } from 'astro:assets';
import toolsBg from '/src/assets/narzedzia.jpg';
---

<section class="relative py-16 md:py-20 lg:py-24 overflow-hidden bg-airtur-dark" aria-labelledby="tools-heading">
  
  <div class="absolute inset-0 z-0">
    <Image 
      src={toolsBg} 
      alt="Osoba analizująca dane na laptopie - optymalizacja kosztów AirTUR" 
      class="w-full h-full object-cover opacity-40 md:opacity-50" 
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-airtur-dark via-airtur-dark/80 to-transparent z-10"></div>
  </div>

  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="max-w-3xl">
      
      <h2 
        id="tools-heading" 
        class="text-3xl md:text-5xl lg:text-6xl font-black text-white mb-6 leading-[1.1] tracking-tight text-balance"
      >
        Decyzje oparte na liczbach. <br class="hidden lg:inline" />
        <span class="text-airtur-blue">Dobieramy system do Twojego budżetu.</span>
      </h2>
      
      <p class="text-base md:text-xl text-white/90 mb-10 leading-relaxed max-w-2xl text-pretty font-medium">
        Wdrożyliśmy zaawansowane modele analityczne, które w oparciu o aktualne ceny energii w Małopolsce, wskażą optymalny system dla Twojej przestrzeni.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a 
          href="/narzedzia" 
          class="inline-flex items-center justify-center bg-airtur-blue text-white px-8 py-4 rounded-xl font-black text-sm md:text-base tracking-widest 
                 hover:bg-airtur-navy active:scale-95
                 transition-all duration-300 shadow-xl uppercase group"
        >
          <span>Przejdź do narzędzi i poznaj konkrety</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5 ml-4 group-hover:translate-x-2 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
      
    </div>
  </div>
</section>