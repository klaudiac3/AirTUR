---
// [DATA]: Dane pozostają bez zmian (Zasada Single Responsibility)
const comparisonData = [
  {
    type: 'problem',
    title: 'Chaos cenowy i niepewność',
    description: 'Rosnące koszty gazu, prądu i paliw stałych sprawiają, że tracisz kontrolę nad finansami. Niepewność rynkowa to wróg Twojego spokoju. Poleganie na jednym źródle ciepła to ryzyko finansowe.',
    iconPath: 'M6 18 18 6M6 6l12 12',
    containerClass: 'bg-red-50/50 border-red-500',
    iconClass: 'text-red-500',
    cta: null
  },
  {
    type: 'solution',
    title: 'Zabezpiecz swój komfort',
    description: 'Nowoczesna klimatyzacja z funkcją grzania to technologia, która strategicznie uniezależnia Cię od wahań cen paliw. To mądry wybór, pozwalający odzyskać poczucie bezpieczeństwa.',
    iconPath: 'm4.5 12.75 6 6 9-13.5',
    containerClass: 'bg-blue-50/50 border-airtur-blue',
    iconClass: 'text-airtur-blue',
    cta: {
      text: 'Dowiedz się więcej o grzaniu',
      url: '/baza-wiedzy'
    }
  }
];
---

<section 
  id="porownanie-kosztow" 
  class="py-12 md:py-16 bg-white" 
  aria-labelledby="problem-solution-title"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <header class="text-center mb-10 md:mb-12">
      <h2 id="problem-solution-title" class="text-3xl md:text-5xl font-black text-airtur-dark leading-[1.1] tracking-tight text-balance max-w-4xl mx-auto">
        Koniec z nieprzewidywalnymi rachunkami. <br class="hidden md:inline" />
        <span class="text-airtur-blue">Przejmij władzę nad swoim budżetem.</span>
      </h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-10 items-stretch">
      {comparisonData.map((item) => (
        <article class={`
          ${item.containerClass} 
          border-l-8 p-8 md:p-10 rounded-3xl flex flex-col h-full 
          shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1
        `}>
          
          <div class="flex items-start gap-5 mb-4">
            <div class="flex-shrink-0 pt-1">
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                fill="none" 
                viewBox="0 0 24 24" 
                stroke-width="3" 
                stroke="currentColor" 
                class={`w-10 h-10 ${item.iconClass}`}
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={item.iconPath} />
              </svg>
            </div>

            <div>
              <h3 class="text-xl md:text-2xl font-black text-airtur-dark mb-3 tracking-tight">
                {item.title}
              </h3>
              <p class="text-gray-500 leading-relaxed text-sm md:text-base text-pretty font-medium">
                {item.description}
              </p>
            </div>
          </div>

          {item.cta && (
            <div class="mt-auto pt-6 sm:pl-15">
              <a 
                href={item.cta.url} 
                class="inline-flex items-center font-black text-sm text-airtur-blue group transition-all uppercase tracking-widest"
              >
                <span class="border-b-4 border-airtur-blue/20 pb-1 group-hover:border-airtur-navy group-hover:text-airtur-navy transition-all">
                  {item.cta.text}
                </span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5 ml-3 group-hover:translate-x-2 transition-transform">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>