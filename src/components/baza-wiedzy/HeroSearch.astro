---
// src/components/baza-wiedzy/HeroSearch.astro
import { getGlobalSearchIndex } from '../../utils/searchIndex';
import FAQ from './FAQ.astro';

/** * [SENIOR NOTE]: Główny moduł wyszukiwania AirTUR.
 * Integracja: searchIndex.js (Deep Data) + FAQ.astro (Deep Linking).
 */

let searchData = [];
try {
  searchData = await getGlobalSearchIndex();
} catch (e) {
  console.error("Błąd krytyczny indeksu wyszukiwarki:", e);
}

const uniqueCategories = [...new Set(searchData.map(item => item.category))].filter(Boolean);

const categoryConfig = {
    'finanse': { label: 'Finanse i ROI', icon: '💰' },
    'zdrowie': { label: 'Zdrowie', icon: '👶' },
    'technologia': { label: 'Technologia', icon: '⚙️' },
    'montaz': { label: 'Montaż', icon: '🔧' },
    'realizacje': { label: 'Realizacje', icon: '🏗️' },
    'ogolne': { label: 'Ogólne', icon: 'ℹ️' },
};
---

<section class="bg-gray-50 pt-10 pb-12 border-b border-gray-200 relative z-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="mb-10 text-center">
      <span class="inline-block px-4 py-1.5 mb-4 rounded-full bg-airtur-blue/10 text-airtur-blue text-[10px] font-black uppercase tracking-[0.2em]">
        Centrum Wiedzy
      </span>
      <h1 class="text-2xl md:text-4xl font-black text-airtur-dark mb-3 tracking-tight uppercase leading-tight text-balance">
        Wszystko, co warto wiedzieć <span class="text-airtur-blue font-black">o klimatyzacji.</span>
      </h1>
      <p class="text-sm md:text-base text-gray-500 max-w-xl mx-auto leading-relaxed font-medium text-pretty">
        Przeszukaj nasze studia przypadków, poradniki techniczne i najczęściej zadawane pytania (FAQ) i znajdź odpowiedzi na swoje pytania.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      
      <div id="faq-column-container" class="w-full order-2 lg:order-1">
        <FAQ />
      </div>

      <div class="w-full order-1 lg:order-2 lg:sticky lg:top-28">
        <div class="bg-white p-6 rounded-2xl shadow-xl shadow-slate-200/60 border border-slate-100">
          
          <div class="flex items-center justify-between mb-4">
            <span class="text-[10px] font-black text-airtur-dark uppercase tracking-widest">Wyszukiwarka</span>
            <span class="flex items-center gap-1.5 text-[9px] text-emerald-600 font-black bg-emerald-50 px-2 py-0.5 rounded-full" aria-hidden="true">
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span> SYSTEM LIVE
            </span>
          </div>
          
          <div class="relative w-full mb-6" id="search-wrapper" data-knowledge={JSON.stringify(searchData)}>
            <input 
              type="text" 
              id="search-input"
              placeholder="Wpisz np. 'Kraków', '7.1kW' lub 'oszczędności'..." 
              class="w-full pl-5 pr-12 py-4 rounded-xl border-2 border-slate-50 bg-gray-50/30 text-sm text-airtur-dark font-medium focus:outline-none focus:border-airtur-blue focus:bg-white focus:ring-4 focus:ring-airtur-blue/5 transition-all placeholder:text-gray-300"
              autocomplete="off"
              aria-label="Przeszukaj bazę wiedzy"
            >
            <div class="absolute right-4 top-1/2 -translate-y-1/2 text-airtur-blue pointer-events-none">
               <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
            </div>
            
            <div id="search-results-dropdown" class="hidden absolute top-full left-0 w-full mt-2 bg-white rounded-xl shadow-2xl border border-slate-100 overflow-hidden z-50 max-h-[400px] overflow-y-auto" role="listbox">
            </div>
          </div>

          <div class="flex flex-wrap gap-2" id="pills-container" role="group" aria-label="Filtruj według kategorii">
            {uniqueCategories.map(catKey => {
              const config = categoryConfig[catKey] || { label: catKey, icon: '📂' };
              return (
                <button 
                  class="filter-pill flex items-center gap-2 px-3 py-2 bg-slate-50 border border-slate-100 rounded-lg hover:border-airtur-blue hover:bg-white transition-all cursor-pointer group" 
                  data-search={catKey}
                  aria-pressed="false"
                >
                  <span class="text-base group-hover:scale-110 transition-transform">{config.icon}</span>
                  <span class="text-[10px] font-black text-gray-500 group-hover:text-airtur-blue uppercase tracking-tight label-text transition-colors">{config.label}</span>
                </button>
              )
            })}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* [UX]: Aktywny stan przycisków kategorii (AirTUR Dark) */
  .filter-pill.active {
    background-color: #1e293b; /* slate-800 */
    border-color: #1e293b;
  }
  .filter-pill.active .label-text {
    color: white !important;
  }
</style>

<script type="module">
    import Fuse from 'https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.mjs';

    // [SECURITY]: Oczyszczanie danych wyjściowych
    const escapeHTML = (str) => {
        if (!str) return "";
        return str.replace(/[&<>"']/g, m => ({
            '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        })[m]);
    };

    // [SENIOR FIX]: Normalizacja tekstu identyczna z serwerową (Kraków -> krakow)
    const normalizeText = (text) => 
        text?.toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .trim() || '';

    try {
        const wrapper = document.getElementById('search-wrapper');
        const knowledgeData = JSON.parse(wrapper.dataset.knowledge || "[]");
        const input = document.getElementById('search-input');
        const dropdown = document.getElementById('search-results-dropdown');
        const pills = document.querySelectorAll('.filter-pill');

        const fuse = new Fuse(knowledgeData, {
            threshold: 0.3,
            ignoreLocation: true,
            keys: [
                { name: 'title', weight: 1.0 },
                { name: 'category', weight: 0.8 },
                { name: 'searchContent', weight: 0.7 },
                { name: 'excerpt', weight: 0.3 }
            ]
        });

        const updatePillsState = (val) => {
            pills.forEach(p => {
                const isActive = p.dataset.search.toLowerCase() === val.toLowerCase();
                p.classList.toggle('active', isActive);
                p.setAttribute('aria-pressed', isActive ? 'true' : 'false');
            });
        };

        const renderResults = (results) => {
            if (results.length > 0) {
                dropdown.innerHTML = results.map(item => `
                    <a href="${item.url}" class="block p-4 border-b border-slate-50 hover:bg-slate-50 transition-colors search-result-link group" data-url="${item.url}" data-cat="${item.category}" data-type="${item.type}" role="option">
                        <div class="flex justify-between items-center mb-1.5">
                            <span class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-md ${
                                item.type === 'faq' ? 'bg-amber-100 text-amber-700' : 
                                item.type === 'case' ? 'bg-purple-100 text-purple-700' : 'bg-airtur-blue/10 text-airtur-blue'
                            }">${item.type === 'faq' ? 'PYTANIE FAQ' : item.type === 'case' ? 'REALIZACJA' : 'ARTYKUŁ'}</span>
                            <span class="text-[9px] text-slate-300 font-bold uppercase">${item.category}</span>
                        </div>
                        <h3 class="text-sm font-black text-airtur-dark leading-snug group-hover:text-airtur-blue transition-colors">${escapeHTML(item.title)}</h3>
                        <p class="text-[11px] text-gray-400 mt-1 line-clamp-1 font-medium">${escapeHTML(item.excerpt)}</p>
                    </a>
                `).join('');
                dropdown.classList.remove('hidden');
            } else {
                dropdown.innerHTML = '<div class="p-6 text-center text-xs text-gray-400 font-black uppercase tracking-widest">Brak wyników wyszukiwania...</div>';
                dropdown.classList.remove('hidden');
            }
        };

        const performSearch = (query) => {
            updatePillsState(query);
            if (query.trim().length < 2) {
                dropdown.classList.add('hidden');
                return;
            }
            
            // [KLUCZOWE]: Normalizacja zapytania przed szukaniem w Fuse
            const normalizedQuery = normalizeText(query);
            const results = fuse.search(normalizedQuery).map(r => r.item).slice(0, 6);
            renderResults(results);
        };

        // Debouncing (150ms) dla płynności
        let searchTimeout;
        input.addEventListener('input', (e) => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => performSearch(e.target.value), 150);
        });

        // Obsługa pigułek (z zatrzymaniem propagacji)
        pills.forEach(pill => {
            pill.addEventListener('click', (e) => {
                e.stopPropagation();
                const category = pill.dataset.search;
                input.value = category;
                performSearch(category);
                input.focus();
            });
        });

        // Zamykanie przy kliknięciu poza
        document.addEventListener('click', (e) => {
            if (!wrapper.contains(e.target) && !e.target.closest('.filter-pill')) {
                dropdown.classList.add('hidden');
            }
        });

        // Nawigacja
        dropdown.addEventListener('click', (e) => {
            const link = e.target.closest('.search-result-link');
            if (link) {
                e.preventDefault();
                const { url, cat, type } = link.dataset;
                const [path, hash] = url.split('#');
                
                if (hash && window.location.pathname.includes(path || 'baza-wiedzy')) {
                    window.dispatchEvent(new CustomEvent('faq-navigate', { detail: { hash, category: cat, type } }));
                } else {
                    window.location.href = url;
                }
                dropdown.classList.add('hidden');
            }
        });

    } catch (err) { console.error("Search Engine Error:", err); }
</script>