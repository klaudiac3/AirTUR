# ==============================================================================
# KONFIGURACJA NAGŁÓWKÓW HTTP - AIRTUR (Wersja Produkcyjna)
# ==============================================================================

# [1] GLOBALNE ZABEZPIECZENIA DLA CAŁEJ WITRYNY
/*
  # Ochrona przed osadzaniem strony w ramkach (Clickjacking)
  X-Frame-Options: DENY

  # Blokada zgadywania typów zawartości (nosniff)
  X-Content-Type-Options: nosniff

  # Kontrola prywatności odsyłaczy
  Referrer-Policy: strict-origin-when-cross-origin

  # Wymuszanie bezpiecznego połączenia HTTPS (HSTS) - 1 rok + preload
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Blokada nieużywanych funkcji urządzenia (Kamera, Mikrofon, Płatności)
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=(), usb=(), interest-cohort=()

  # Ochrona przed atakami XSS (Legacy Fallback)
  X-XSS-Protection: 1; mode=block

  # POLITYKA BEZPIECZEŃSTWA TREŚCI (CSP)
  # Blokuje wstrzykiwanie obcych skryptów. Pozwala na skrypty/style lokalne i inline (Astro).
  # Jeśli dodasz Google Analytics w przyszłości, dopiszemy domeny google do script-src i connect-src.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self';


# [2] AGRESYWNE BUFOROWANIE (ASSETY ASTRO)
# Tutaj trafiają grafiki z src/assets (np. hero.jpg, narzedzia.jpg) oraz pliki JS/CSS.
# Astro nadaje im unikalne nazwy (hashe), więc mogą być cache'owane na zawsze (immutable).
/_astro/*
  Cache-Control: public, max-age=31536000, immutable


# [3] BUFOROWANIE CZCIONEK (PUBLIC/FONTS)
# Czcionki rzadko się zmieniają, dlatego ustawiamy max-age na rok.
/fonts/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/fonts/*.ttf
  Cache-Control: public, max-age=31536000, immutable


# [4] STANDARDOWE BUFOROWANIE (ZASOBY W PUBLIC)
# Dotyczy grafik, które jeszcze tam zostały, oraz favicon i manifestu.
# Ustawiamy 7 dni + must-revalidate (przeglądarka sprawdzi, czy nie ma nowszej wersji po tygodniu).

# Obrazy (JPG, PNG, WebP, SVG)
/*.jpg
  Cache-Control: public, max-age=604800, must-revalidate
/*.png
  Cache-Control: public, max-age=604800, must-revalidate
/*.webp
  Cache-Control: public, max-age=604800, must-revalidate
/*.svg
  Cache-Control: public, max-age=604800, must-revalidate

# Ikony i manifesty
/*.ico
  Cache-Control: public, max-age=604800, must-revalidate
/*.webmanifest
  Cache-Control: public, max-age=604800, must-revalidate